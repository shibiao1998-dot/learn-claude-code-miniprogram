/* subpkg-chapters/pages/bridge-doc/bridge-doc.wxss */

.page {
  min-height: 100vh;
  background: var(--color-bg);
  color: var(--color-text-primary);
  font-size: var(--font-base);
  display: flex;
  flex-direction: column;
}

/* ══════════════════════════════════════════
   顶部 Header
══════════════════════════════════════════ */
.bd-header {
  padding: var(--spacing-lg) var(--spacing-md) var(--spacing-md);
  background: var(--color-bg-card);
  box-shadow: var(--shadow-sm);
}

.bd-header__meta {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: var(--spacing-xs);
  margin-bottom: var(--spacing-sm);
}

.bd-kind-badge {
  font-size: var(--font-xs);
  font-weight: 600;
  padding: 4rpx 16rpx;
  border-radius: var(--radius-sm);
  border: 1rpx solid;
  letter-spacing: 0.5rpx;
}

.bd-kind-badge--map {
  background: #05966918;
  color: var(--color-core);
  border-color: #05966944;
}

.bd-kind-badge--mechanism {
  background: #2563EB18;
  color: var(--color-hardening);
  border-color: #2563EB44;
}

.bd-title {
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--color-text-primary);
  line-height: 1.3;
  display: block;
  margin-bottom: var(--spacing-sm);
}

.bd-summary-block {
  display: flex;
  flex-direction: row;
  gap: var(--spacing-sm);
  background: var(--color-bg-muted);
  border-radius: var(--radius-sm);
  padding: var(--spacing-sm) var(--spacing-md);
}

.bd-summary-block__bar {
  width: 4rpx;
  background: var(--color-accent-blue);
  border-radius: 2rpx;
  flex-shrink: 0;
}

.bd-summary-block__text {
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
  line-height: 1.6;
  font-style: italic;
  flex: 1;
}

/* ══════════════════════════════════════════
   加载 / 未找到
══════════════════════════════════════════ */
.bd-loading {
  padding: var(--spacing-xl);
  display: flex;
  justify-content: center;
}

.bd-loading__text {
  font-size: var(--font-sm);
  color: var(--color-text-muted);
}

.bd-not-found {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--spacing-md);
  padding: 120rpx var(--spacing-lg);
}

.bd-not-found__icon {
  font-size: 80rpx;
}

.bd-not-found__title {
  font-size: var(--font-md);
  font-weight: 700;
  color: var(--color-text-secondary);
}

.bd-not-found__slug {
  font-size: var(--font-sm);
  color: var(--color-text-muted);
  font-family: 'Courier New', monospace;
}

/* ══════════════════════════════════════════
   文档内容（Markdown 节点 - 复用 chapter 样式）
══════════════════════════════════════════ */
.doc-content {
  padding: var(--spacing-md);
  flex: 1;
}

/* 标题 */
.md-h1 {
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--color-text-primary);
  margin: var(--spacing-lg) 0 var(--spacing-sm);
  line-height: 1.3;
}

.md-h2 {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: var(--spacing-xs);
  font-size: var(--font-md);
  font-weight: 700;
  color: var(--color-text-primary);
  margin: var(--spacing-xl) 0 var(--spacing-sm);
  padding-bottom: var(--spacing-xs);
  border-bottom: 1rpx solid var(--color-border);
}

.md-h2__bar {
  width: 6rpx;
  height: 32rpx;
  background: var(--color-accent-blue);
  border-radius: 3rpx;
  flex-shrink: 0;
}

.md-h3 {
  font-size: var(--font-base);
  font-weight: 600;
  color: var(--color-text-secondary);
  margin: var(--spacing-md) 0 var(--spacing-xs);
}

/* blockquote */
.md-blockquote {
  display: flex;
  flex-direction: row;
  gap: var(--spacing-sm);
  background: var(--color-bg-muted);
  border-radius: var(--radius-sm);
  padding: var(--spacing-sm) var(--spacing-md);
  margin: var(--spacing-sm) 0;
}

.md-blockquote__bar {
  width: 4rpx;
  background: var(--color-accent-blue);
  border-radius: 2rpx;
  flex-shrink: 0;
}

.md-blockquote__text {
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
  line-height: 1.6;
  font-style: italic;
}

/* hr */
.md-hr {
  height: 1rpx;
  background: var(--color-border);
  margin: var(--spacing-lg) 0;
}

/* 列表项 */
.md-li {
  display: flex;
  flex-direction: row;
  gap: var(--spacing-xs);
  margin: var(--spacing-xs) 0;
  padding-left: var(--spacing-xs);
}

.md-li__dot {
  color: var(--color-accent-blue);
  font-size: var(--font-base);
  line-height: 1.6;
  flex-shrink: 0;
  margin-top: 2rpx;
}

.md-li__text {
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
  line-height: 1.6;
  flex: 1;
}

/* 代码块 */
.md-code-block {
  background: #0D1117;
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-md);
  margin: var(--spacing-md) 0;
  overflow: hidden;
}

.md-code-block__header {
  background: var(--color-bg-muted);
  padding: 8rpx var(--spacing-md);
  border-bottom: 1rpx solid var(--color-border);
}

.md-code-block__lang {
  font-size: var(--font-xs);
  color: var(--color-text-muted);
  font-family: 'Courier New', monospace;
  letter-spacing: 0.5rpx;
}

.md-code-block__scroll {
  width: 100%;
}

.md-code-block__text {
  font-family: 'Courier New', Courier, monospace;
  font-size: var(--font-xs);
  color: #D4D4D4;
  line-height: 1.7;
  padding: var(--spacing-md);
  display: block;
  white-space: pre;
}

/* ── 表格 ── */
.md-table-wrap {
  margin: var(--spacing-md) 0;
  border-radius: 12rpx;
  overflow: hidden;
  border: 1rpx solid var(--color-border);
}

.md-table-scroll {
  width: 100%;
}

.md-table {
  display: flex;
  flex-direction: column;
  min-width: 100%;
}

.md-table__row {
  display: flex;
  flex-direction: row;
  border-bottom: 1rpx solid var(--color-border);
}

.md-table__row:last-child {
  border-bottom: none;
}

.md-table__row--header {
  background: var(--color-bg-muted);
}

.md-table__cell {
  flex: 1;
  min-width: 160rpx;
  padding: 16rpx 20rpx;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  line-height: 1.5;
  border-right: 1rpx solid var(--color-border);
  word-break: break-word;
}

.md-table__cell:last-child {
  border-right: none;
}

.md-table__cell--header {
  font-weight: 600;
  color: var(--color-text-primary);
  font-size: 24rpx;
  background: var(--color-bg-muted);
}

/* 段落 */
.md-paragraph {
  margin: var(--spacing-sm) 0;
}

.md-paragraph__text {
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
  line-height: 1.7;
}

/* ══════════════════════════════════════════
   底部安全距离
══════════════════════════════════════════ */
.safe-bottom {
  height: env(safe-area-inset-bottom, 30rpx);
  height: calc(env(safe-area-inset-bottom, 0) + 30rpx);
}

/* ══════════════════════════════════════════
   Card Detail Mode
══════════════════════════════════════════ */
.card-detail {
  padding: var(--spacing-lg) var(--spacing-md);
  display: flex;
  flex-direction: column;
  gap: var(--spacing-lg);
}

.card-visual {
  background: var(--color-bg-card);
  box-shadow: var(--shadow-sm);
  border-radius: var(--radius-lg);
  padding: var(--spacing-lg);
  display: flex;
  flex-direction: column;
  gap: var(--spacing-md);
}

.card-visual--N { border-top: 4rpx solid var(--color-rarity-n); }
.card-visual--R { border-top: 4rpx solid var(--color-rarity-r); }
.card-visual--SR { border-top: 4rpx solid var(--color-rarity-sr); box-shadow: 0 0 20rpx rgba(188, 140, 255, 0.1); }
.card-visual--SSR { border-top: 4rpx solid var(--color-rarity-ssr); box-shadow: 0 0 30rpx rgba(240, 192, 64, 0.15); }

.card-visual__header {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
}

.card-visual__rarity {
  font-size: var(--font-sm);
  font-weight: 700;
}

.card-visual--N .card-visual__rarity { color: var(--color-rarity-n); }
.card-visual--R .card-visual__rarity { color: var(--color-rarity-r); }
.card-visual--SR .card-visual__rarity { color: var(--color-rarity-sr); }
.card-visual--SSR .card-visual__rarity { color: var(--color-rarity-ssr); }

.card-visual__region {
  font-size: var(--font-xs);
  font-weight: 600;
}

.card-visual__name {
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--color-text-primary);
  line-height: 1.3;
}

.card-visual__desc {
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
  line-height: 1.7;
}

.card-visual__stats {
  display: flex;
  flex-direction: row;
  gap: var(--spacing-lg);
  padding-top: var(--spacing-sm);
  border-top: 1rpx solid var(--color-border);
}

.card-stat {
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
}

.card-visual__tags {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: var(--spacing-xs);
}

.card-tag {
  font-size: var(--font-2xs);
  color: var(--color-text-muted);
  background: var(--color-bg-elevated);
  padding: 4rpx 12rpx;
  border-radius: var(--radius-sm);
}

.card-meta {
  background: var(--color-bg-card);
  box-shadow: var(--shadow-sm);
  border-radius: var(--radius-md);
  padding: var(--spacing-md);
  display: flex;
  flex-direction: column;
  gap: var(--spacing-sm);
}

.card-meta__row {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
}

.card-meta__label {
  font-size: var(--font-xs);
  color: var(--color-text-muted);
}

.card-meta__value {
  font-size: var(--font-sm);
  color: var(--color-text-primary);
}

.card-back-btn {
  padding: var(--spacing-md);
  background: var(--color-bg-elevated);
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-md);
  display: flex;
  justify-content: center;
}

.card-back-btn__text {
  font-size: var(--font-sm);
  font-weight: 700;
  color: var(--color-text-primary);
}

.card-back-btn:active {
  background: var(--color-bg-muted);
  transform: scale(0.95);
  transition: transform 0.15s ease;
}

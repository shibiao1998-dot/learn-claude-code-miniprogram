/* subpkg-chapters/pages/chapter/chapter.wxss */

/* ══════════════════════════════════════════
   页面容器
══════════════════════════════════════════ */
.page {
  min-height: 100vh;
  background: var(--color-bg);
  color: var(--color-text-primary);
  font-size: var(--font-base);
  display: flex;
  flex-direction: column;
}

/* ══════════════════════════════════════════
   Tab 栏（固定顶部）
══════════════════════════════════════════ */
.tab-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  display: flex;
  flex-direction: row;
  background: var(--color-bg-card);
  border-bottom: 1rpx solid var(--color-border);
  /* 安全区：状态栏高度用 env(safe-area-inset-top) 处理，开发者工具用 padding-top */
  padding-top: env(safe-area-inset-top, 0);
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: var(--spacing-sm) 0;
  position: relative;
  min-height: 88rpx;
}

.tab-label {
  font-size: var(--font-sm);
  color: var(--color-text-muted);
  letter-spacing: 0.5rpx;
  transition: color 0.2s;
}

.tab-item--active .tab-label {
  color: var(--color-accent);
  font-weight: 600;
}

.tab-indicator {
  position: absolute;
  bottom: 0;
  left: 20%;
  right: 20%;
  height: 3rpx;
  background: var(--color-accent);
  border-radius: 3rpx 3rpx 0 0;
}

/* ══════════════════════════════════════════
   滚动内容区（留出 Tab 栏高度）
══════════════════════════════════════════ */
.content-scroll {
  /* Tab 栏约 88rpx + 状态栏；用 calc 兼容 */
  height: calc(100vh - 88rpx);
  margin-top: calc(88rpx + env(safe-area-inset-top, 0));
  box-sizing: border-box;
}

/* ══════════════════════════════════════════
   章节 Header
══════════════════════════════════════════ */
.chapter-header {
  padding: var(--spacing-lg) var(--spacing-md);
  background: var(--color-bg-card);
  border-bottom: 1rpx solid var(--color-border);
}

/* 图层徽章 */
.layer-badge {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 16rpx;
  border-radius: var(--radius-sm);
  border: 1rpx solid;
  margin-bottom: var(--spacing-sm);
}

.layer-badge__text {
  font-size: var(--font-xs);
  font-weight: 600;
  letter-spacing: 1rpx;
  text-transform: uppercase;
}

/* 标题行 */
.title-row {
  display: flex;
  flex-direction: row;
  align-items: baseline;
  gap: var(--spacing-sm);
  margin-bottom: var(--spacing-xs);
  flex-wrap: wrap;
}

.chapter-id-label {
  font-size: var(--font-sm);
  color: var(--color-text-muted);
  font-family: 'Courier New', monospace;
  font-weight: 500;
}

.chapter-title {
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--color-text-primary);
  line-height: 1.3;
}

/* 副标题 */
.chapter-subtitle {
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
  margin-bottom: var(--spacing-sm);
  line-height: 1.5;
}

/* keyInsight 引用块 */
.insight-block {
  display: flex;
  flex-direction: row;
  gap: var(--spacing-sm);
  background: var(--color-accent)11;
  border-radius: var(--radius-sm);
  padding: var(--spacing-sm) var(--spacing-md);
  margin: var(--spacing-sm) 0;
}

.insight-bar {
  width: 4rpx;
  background: var(--color-accent);
  border-radius: 2rpx;
  flex-shrink: 0;
}

.insight-text {
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
  line-height: 1.6;
  font-style: italic;
}

/* 核心新增 */
.core-addition {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: var(--spacing-xs);
  margin: var(--spacing-xs) 0;
}

.core-addition__label {
  font-size: var(--font-xs);
  color: var(--color-text-muted);
  background: var(--color-bg-muted);
  padding: 2rpx 10rpx;
  border-radius: var(--radius-sm);
  flex-shrink: 0;
}

.core-addition__text {
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
  font-family: 'Courier New', monospace;
}

/* 元信息行 */
.meta-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: var(--spacing-sm);
  margin: var(--spacing-sm) 0;
  flex-wrap: wrap;
}

.meta-item {
  display: flex;
  flex-direction: row;
  align-items: baseline;
  gap: 4rpx;
}

.meta-value {
  font-size: var(--font-md);
  font-weight: 700;
  color: var(--color-text-primary);
  font-family: 'Courier New', monospace;
}

.meta-unit {
  font-size: var(--font-xs);
  color: var(--color-text-muted);
}

.meta-divider {
  width: 1rpx;
  height: 28rpx;
  background: var(--color-border);
}

.meta-tools {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: var(--spacing-xs);
}

.tool-tag {
  font-size: var(--font-xs);
  color: var(--color-text-muted);
  background: var(--color-bg-muted);
  padding: 4rpx 14rpx;
  border-radius: var(--radius-sm);
  font-family: 'Courier New', monospace;
}

.tool-tag--new {
  color: var(--color-core);
  background: #34D39918;
  border: 1rpx solid #34D39940;
}

/* 已读徽章 */
.read-badge {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  margin-top: var(--spacing-xs);
}

.read-badge__icon {
  font-size: var(--font-xs);
  color: var(--color-core);
}

.read-badge__text {
  font-size: var(--font-xs);
  color: var(--color-text-muted);
}

/* ── 导读区 ── */
.guide-section {
  margin-top: var(--spacing-md);
  border-top: 1rpx solid var(--color-border);
  padding-top: var(--spacing-sm);
}

.guide-toggle {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: var(--spacing-xs) 0;
}

.guide-toggle__label {
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
  font-weight: 500;
}

.guide-toggle__arrow {
  font-size: var(--font-xs);
  color: var(--color-text-muted);
  transition: transform 0.2s;
  display: inline-block;
}

.guide-toggle__arrow--open {
  transform: rotate(180deg);
}

.guide-body {
  display: none;
  flex-direction: column;
  gap: var(--spacing-sm);
  padding: var(--spacing-sm) 0;
}

.guide-body--open {
  display: flex;
}

.guide-item {
  background: var(--color-bg-muted);
  border-radius: var(--radius-sm);
  padding: var(--spacing-sm);
}

.guide-item__head {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: var(--spacing-xs);
  margin-bottom: 8rpx;
}

.guide-item__dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.guide-item__dot--focus    { background: var(--color-accent); }
.guide-item__dot--confusion { background: #F59E0B; }
.guide-item__dot--goal     { background: var(--color-core); }

.guide-item__label {
  font-size: var(--font-xs);
  color: var(--color-text-muted);
  font-weight: 600;
  letter-spacing: 0.5rpx;
}

.guide-item__text {
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
  line-height: 1.6;
  display: block;
}

/* ══════════════════════════════════════════
   Learn Tab —— Markdown 渲染
══════════════════════════════════════════ */
.doc-content {
  padding: var(--spacing-md);
}

/* 标题 */
.md-h1 {
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--color-text-primary);
  margin: var(--spacing-lg) 0 var(--spacing-sm);
  line-height: 1.3;
}

.md-h2 {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: var(--spacing-xs);
  font-size: var(--font-md);
  font-weight: 700;
  color: var(--color-text-primary);
  margin: var(--spacing-xl) 0 var(--spacing-sm);
  padding-bottom: var(--spacing-xs);
  border-bottom: 1rpx solid var(--color-border);
}

.md-h2__bar {
  width: 6rpx;
  height: 32rpx;
  background: var(--color-accent);
  border-radius: 3rpx;
  flex-shrink: 0;
}

.md-h3 {
  font-size: var(--font-base);
  font-weight: 600;
  color: var(--color-text-secondary);
  margin: var(--spacing-md) 0 var(--spacing-xs);
}

/* blockquote */
.md-blockquote {
  display: flex;
  flex-direction: row;
  gap: var(--spacing-sm);
  background: var(--color-bg-muted);
  border-radius: var(--radius-sm);
  padding: var(--spacing-sm) var(--spacing-md);
  margin: var(--spacing-sm) 0;
}

.md-blockquote__bar {
  width: 4rpx;
  background: var(--color-accent);
  border-radius: 2rpx;
  flex-shrink: 0;
}

.md-blockquote__text {
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
  line-height: 1.6;
  font-style: italic;
}

/* hr */
.md-hr {
  height: 1rpx;
  background: var(--color-border);
  margin: var(--spacing-lg) 0;
}

/* 列表项 */
.md-li {
  display: flex;
  flex-direction: row;
  gap: var(--spacing-xs);
  margin: var(--spacing-xs) 0;
  padding-left: var(--spacing-xs);
}

.md-li__dot {
  color: var(--color-accent);
  font-size: var(--font-base);
  line-height: 1.6;
  flex-shrink: 0;
  margin-top: 2rpx;
}

.md-li__text {
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
  line-height: 1.6;
  flex: 1;
}

/* 代码块 */
.md-code-block {
  background: #0D1117;
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-md);
  margin: var(--spacing-md) 0;
  overflow: hidden;
}

.md-code-block__header {
  background: var(--color-bg-muted);
  padding: 8rpx var(--spacing-md);
  border-bottom: 1rpx solid var(--color-border);
}

.md-code-block__lang {
  font-size: var(--font-xs);
  color: var(--color-text-muted);
  font-family: 'Courier New', monospace;
  letter-spacing: 0.5rpx;
}

.md-code-block__scroll {
  width: 100%;
}

.md-code-block__text {
  font-family: 'Courier New', Courier, monospace;
  font-size: var(--font-xs);
  color: #D4D4D4;
  line-height: 1.7;
  padding: var(--spacing-md);
  display: block;
  white-space: pre;
}

/* 段落 */
.md-paragraph {
  margin: var(--spacing-sm) 0;
}

.md-paragraph__text {
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
  line-height: 1.7;
}

/* 空状态 */
.empty-state {
  padding: var(--spacing-xl);
  display: flex;
  justify-content: center;
}

.empty-state__text {
  font-size: var(--font-sm);
  color: var(--color-text-muted);
}

/* ══════════════════════════════════════════
   Code Tab
══════════════════════════════════════════ */
.code-viewer {
  display: flex;
  flex-direction: column;
}

/* 文件头 */
.code-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: var(--spacing-sm) var(--spacing-md);
  background: var(--color-bg-card);
  border-bottom: 1rpx solid var(--color-border);
}

.code-header__left {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.code-header__filename {
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
  font-family: 'Courier New', monospace;
}

.code-header__loc {
  font-size: var(--font-xs);
  color: var(--color-text-muted);
}

.code-header__copy {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 6rpx;
  background: var(--color-bg-muted);
  padding: 10rpx 20rpx;
  border-radius: var(--radius-sm);
  border: 1rpx solid var(--color-border);
}

.code-header__copy-icon {
  font-size: var(--font-base);
  color: var(--color-text-secondary);
}

.code-header__copy-label {
  font-size: var(--font-xs);
  color: var(--color-text-secondary);
}

/* 函数/类导航 */
.func-nav {
  padding: var(--spacing-xs) var(--spacing-md);
  background: var(--color-bg);
  border-bottom: 1rpx solid var(--color-border);
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: var(--spacing-sm);
}

.func-nav__title {
  font-size: var(--font-xs);
  color: var(--color-text-muted);
  flex-shrink: 0;
}

.func-nav__scroll {
  flex: 1;
  white-space: nowrap;
}

.func-nav__list {
  display: flex;
  flex-direction: row;
  gap: var(--spacing-xs);
  padding-bottom: 4rpx;
}

.func-tag {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  padding: 6rpx 14rpx;
  border-radius: var(--radius-sm);
  font-size: var(--font-xs);
  font-family: 'Courier New', monospace;
  flex-shrink: 0;
}

.func-tag--class {
  background: var(--color-hardening)18;
  color: var(--color-hardening);
  border: 1rpx solid var(--color-hardening)40;
}

.func-tag--func {
  background: var(--color-accent)18;
  color: var(--color-accent);
  border: 1rpx solid var(--color-accent)40;
}

.func-tag__prefix {
  font-size: var(--font-xs);
  font-weight: 700;
  opacity: 0.7;
}

/* 截断提示 */
.truncate-tip {
  padding: var(--spacing-xs) var(--spacing-md);
  background: #F59E0B18;
  border-bottom: 1rpx solid #F59E0B30;
}

.truncate-tip__text {
  font-size: var(--font-xs);
  color: #F59E0B;
}

/* 代码正文 */
.code-body {
  flex: 1;
}

.code-scroll {
  width: 100%;
  /* 高度 = 视口高度 - Tab栏 - 文件头 - 导航条 - 章节header 约 */
  height: calc(100vh - 300rpx);
  background: #0D1117;
}

.code-lines {
  padding: var(--spacing-sm) 0;
  min-width: 100%;
}

.code-line {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  min-height: 40rpx;
}

.code-line__num {
  font-family: 'Courier New', monospace;
  font-size: 22rpx;
  color: #4A5568;
  text-align: right;
  width: 72rpx;
  min-width: 72rpx;
  padding-right: 16rpx;
  padding-top: 2rpx;
  user-select: none;
  flex-shrink: 0;
  line-height: 1.6;
}

.code-line__tokens {
  flex: 1;
  display: flex;
  flex-direction: row;
  flex-wrap: nowrap;
  padding-right: var(--spacing-md);
}

.code-token {
  font-family: 'Courier New', Courier, monospace;
  font-size: 24rpx;
  line-height: 1.6;
  white-space: pre;
}

/* 加载中 */
.code-loading {
  padding: var(--spacing-xl);
  display: flex;
  justify-content: center;
  align-items: center;
}

.code-loading__text {
  font-size: var(--font-sm);
  color: var(--color-text-muted);
}

/* ══════════════════════════════════════════
   Deep Dive 占位
══════════════════════════════════════════ */
.coming-soon {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx var(--spacing-lg);
  gap: var(--spacing-md);
}

.coming-soon__icon {
  font-size: 80rpx;
}

.coming-soon__title {
  font-size: var(--font-md);
  font-weight: 700;
  color: var(--color-text-secondary);
}

.coming-soon__desc {
  font-size: var(--font-sm);
  color: var(--color-text-muted);
  text-align: center;
  line-height: 1.6;
}

/* ══════════════════════════════════════════
   底部前后导航
══════════════════════════════════════════ */
.nav-footer {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: var(--spacing-md);
  border-top: 1rpx solid var(--color-border);
  background: var(--color-bg-card);
  gap: var(--spacing-sm);
}

.nav-btn {
  flex: 1;
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: var(--spacing-xs);
  padding: var(--spacing-sm) var(--spacing-md);
  background: var(--color-bg-muted);
  border-radius: var(--radius-md);
  border: 1rpx solid var(--color-border);
  min-height: 80rpx;
}

.nav-btn--right {
  justify-content: flex-end;
}

.nav-btn--disabled {
  opacity: 0.4;
}

.nav-btn__arrow {
  font-size: var(--font-md);
  color: var(--color-accent);
  flex-shrink: 0;
}

.nav-btn__label {
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
  font-family: 'Courier New', monospace;
}

.nav-footer__divider {
  width: 1rpx;
  height: 48rpx;
  background: var(--color-border);
  flex-shrink: 0;
}

/* ══════════════════════════════════════════
   底部安全距离
══════════════════════════════════════════ */
.safe-bottom {
  height: env(safe-area-inset-bottom, 30rpx);
  height: calc(env(safe-area-inset-bottom, 0) + 30rpx);
}

/* ══════════════════════════════════════════
   Deep Dive Tab
══════════════════════════════════════════ */
.deep-dive {
  padding: var(--spacing-md);
  display: flex;
  flex-direction: column;
  gap: var(--spacing-lg);
}

.deep-dive__loading {
  padding: var(--spacing-xl);
  display: flex;
  justify-content: center;
}

.deep-dive__loading-text {
  font-size: var(--font-sm);
  color: var(--color-text-muted);
}

/* ── 通用 Section ── */
.dd-section {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-sm);
}

.dd-section__head {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: var(--spacing-xs);
  margin-bottom: var(--spacing-xs);
}

.dd-section__bar {
  width: 6rpx;
  height: 32rpx;
  background: var(--color-accent);
  border-radius: 3rpx;
  flex-shrink: 0;
}

.dd-section__title {
  font-size: var(--font-md);
  font-weight: 700;
  color: var(--color-text-primary);
}

/* ── 执行流程图 ── */
.dd-flow {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0;
  padding: var(--spacing-sm) 0;
}

.dd-flow-node {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
}

.dd-flow-node__box {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: var(--spacing-xs) var(--spacing-md);
  min-width: 240rpx;
  max-width: 500rpx;
  border: 2rpx solid var(--color-border);
  background: var(--color-bg-card);
  text-align: center;
}

/* 节点类型变体 */
.dd-flow-node--start .dd-flow-node__box,
.dd-flow-node--end .dd-flow-node__box {
  border-radius: 100rpx;
  background: var(--color-accent)1A;
  border-color: var(--color-accent)66;
}

.dd-flow-node--decision .dd-flow-node__box {
  border-radius: var(--radius-sm);
  background: #F59E0B18;
  border-color: #F59E0B66;
  transform: skewX(-8deg);
}

.dd-flow-node--decision .dd-flow-node__label {
  transform: skewX(8deg);
  display: block;
}

.dd-flow-node--process .dd-flow-node__box {
  border-radius: var(--radius-sm);
}

.dd-flow-node--subprocess .dd-flow-node__box {
  border-radius: var(--radius-sm);
  border-style: double;
  border-width: 4rpx;
  background: var(--color-hardening)12;
  border-color: var(--color-hardening)55;
}

.dd-flow-node__label {
  font-size: var(--font-sm);
  color: var(--color-text-primary);
  font-weight: 500;
  line-height: 1.4;
}

.dd-flow-arrow {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0;
  padding: 4rpx 0;
}

.dd-flow-arrow__line {
  font-size: var(--font-md);
  color: var(--color-text-muted);
  line-height: 1;
}

.dd-flow-arrow__label {
  font-size: var(--font-xs);
  color: var(--color-accent);
  background: var(--color-accent)18;
  border-radius: var(--radius-sm);
  padding: 2rpx 10rpx;
  max-width: 300rpx;
  text-align: center;
}

/* ── 架构蓝图 ── */
.dd-blueprint-summary {
  background: var(--color-bg-card);
  border-radius: var(--radius-md);
  padding: var(--spacing-sm) var(--spacing-md);
  border: 1rpx solid var(--color-border);
}

.dd-blueprint-summary__text {
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
  line-height: 1.7;
}

.dd-blueprint-slice {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-xs);
}

.dd-blueprint-slice__label {
  font-size: var(--font-xs);
  color: var(--color-text-muted);
  font-weight: 600;
  letter-spacing: 1rpx;
  text-transform: uppercase;
  padding: var(--spacing-xs) 0 4rpx;
  border-bottom: 1rpx solid var(--color-border);
  display: block;
}

.dd-blueprint-item {
  background: var(--color-bg-card);
  border-radius: var(--radius-sm);
  padding: var(--spacing-sm) var(--spacing-md);
  border-left: 3rpx solid var(--color-border);
}

.dd-blueprint-item--record {
  border-left-color: var(--color-core);
  background: #34D39910;
}

.dd-blueprint-item__head {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: var(--spacing-xs);
  margin-bottom: 6rpx;
}

.dd-blueprint-item__name {
  font-size: var(--font-sm);
  color: var(--color-text-primary);
  font-weight: 600;
}

.dd-blueprint-item__name--mono {
  font-family: 'Courier New', monospace;
  color: var(--color-core);
}

.dd-blueprint-item__badge {
  font-size: var(--font-xs);
  color: var(--color-accent);
  background: var(--color-accent)1A;
  border: 1rpx solid var(--color-accent)55;
  border-radius: var(--radius-sm);
  padding: 2rpx 10rpx;
  flex-shrink: 0;
}

.dd-blueprint-item__badge--record {
  color: var(--color-core);
  background: #34D39918;
  border-color: #34D39955;
}

.dd-blueprint-item__detail {
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
  line-height: 1.6;
  display: block;
}

/* Handoff */
.dd-handoff-item {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  gap: var(--spacing-sm);
  padding: var(--spacing-xs) 0;
}

.dd-handoff-item__num {
  width: 40rpx;
  height: 40rpx;
  min-width: 40rpx;
  border-radius: 50%;
  background: var(--color-accent);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-xs);
  color: var(--color-bg);
  font-weight: 700;
  flex-shrink: 0;
  margin-top: 4rpx;
}

.dd-handoff-item__text {
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
  line-height: 1.6;
  flex: 1;
}

/* ── Agent Loop 模拟器 ── */
.dd-sim-controls {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: var(--spacing-sm);
  padding: var(--spacing-sm) 0;
}

.dd-sim-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: var(--spacing-xs) var(--spacing-sm);
  background: var(--color-bg-muted);
  border-radius: var(--radius-sm);
  border: 1rpx solid var(--color-border);
}

.dd-sim-btn--reset {
  background: transparent;
  border-color: var(--color-text-muted);
}

.dd-sim-btn__text {
  font-size: var(--font-xs);
  color: var(--color-accent);
  font-weight: 500;
}

.dd-sim-btn--reset .dd-sim-btn__text {
  color: var(--color-text-muted);
}

.dd-sim-progress {
  flex: 1;
  text-align: center;
  font-size: var(--font-xs);
  color: var(--color-text-muted);
  font-family: 'Courier New', monospace;
}

.dd-sim-steps {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-xs);
}

.dd-sim-step {
  border-radius: var(--radius-sm);
  padding: var(--spacing-sm) var(--spacing-md);
  border: 1rpx solid var(--color-border);
  background: var(--color-bg-card);
  opacity: 0.5;
  transition: opacity 0.2s;
}

.dd-sim-step--active {
  opacity: 1;
  border-color: var(--color-accent)66;
  background: var(--color-bg-muted);
}

/* 步骤类型颜色 */
.dd-sim-step--user_message {
  border-left: 4rpx solid var(--color-core);
}

.dd-sim-step--user_message.dd-sim-step--active {
  border-left-color: var(--color-core);
  background: #34D39910;
}

.dd-sim-step--assistant_text {
  border-left: 4rpx solid var(--color-hardening);
}

.dd-sim-step--assistant_text.dd-sim-step--active {
  background: #60A5FA10;
}

.dd-sim-step--tool_call {
  border-left: 4rpx solid #F59E0B;
}

.dd-sim-step--tool_call.dd-sim-step--active {
  background: #F59E0B10;
}

.dd-sim-step--tool_result {
  border-left: 4rpx solid var(--color-runtime);
}

.dd-sim-step--tool_result.dd-sim-step--active {
  background: #A78BFA10;
}

.dd-sim-step__header {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: var(--spacing-xs);
  margin-bottom: 6rpx;
}

.dd-sim-step__type-tag {
  font-size: var(--font-xs);
  color: var(--color-text-muted);
  font-family: 'Courier New', monospace;
  background: var(--color-bg);
  padding: 2rpx 8rpx;
  border-radius: var(--radius-sm);
  border: 1rpx solid var(--color-border);
}

.dd-sim-step__tool {
  font-size: var(--font-xs);
  color: #F59E0B;
  font-family: 'Courier New', monospace;
  font-weight: 600;
}

.dd-sim-step__content {
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
  line-height: 1.5;
  display: block;
  font-family: 'Courier New', monospace;
}

.dd-sim-step__annotation {
  display: block;
  font-size: var(--font-xs);
  color: #6A9955;
  font-style: italic;
  margin-top: 6rpx;
  line-height: 1.5;
}

/* ── Bridge Doc 链接卡片 ── */
.dd-bridge-card {
  background: var(--color-bg-card);
  border-radius: var(--radius-md);
  padding: var(--spacing-sm) var(--spacing-md);
  border: 1rpx solid var(--color-border);
  margin-bottom: var(--spacing-xs);
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.dd-bridge-card__top {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: var(--spacing-xs);
}

.dd-bridge-card__kind {
  font-size: var(--font-xs);
  padding: 2rpx 10rpx;
  border-radius: var(--radius-sm);
  font-weight: 600;
  flex-shrink: 0;
}

.dd-bridge-card__kind--map {
  background: var(--color-core)1A;
  color: var(--color-core);
  border: 1rpx solid var(--color-core)44;
}

.dd-bridge-card__kind--mechanism {
  background: var(--color-hardening)1A;
  color: var(--color-hardening);
  border: 1rpx solid var(--color-hardening)44;
}

.dd-bridge-card__title {
  font-size: var(--font-sm);
  color: var(--color-text-primary);
  font-weight: 600;
  flex: 1;
}

.dd-bridge-card__arrow {
  font-size: var(--font-lg);
  color: var(--color-text-muted);
  flex-shrink: 0;
}

.dd-bridge-card__summary {
  font-size: var(--font-xs);
  color: var(--color-text-secondary);
  line-height: 1.6;
  display: block;
}

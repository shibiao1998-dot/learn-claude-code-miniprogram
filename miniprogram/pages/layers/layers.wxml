<!-- pages/layers/layers.wxml -->
<scroll-view class="page-scroll" scroll-y enhanced>

  <!-- ====== 头部 ====== -->
  <view class="page-header">
    <view class="header-content">
      <text class="header-title">{{t.layers.title}}</text>
      <text class="header-subtitle">{{t.layers.subtitle}}</text>
    </view>
    <!-- 语言切换 -->
    <view class="locale-switcher">
      <text
        class="locale-btn {{locale === 'zh' ? 'locale-btn--active' : ''}}"
        data-locale="zh"
        bindtap="switchLocale"
      >中</text>
      <text
        class="locale-btn {{locale === 'en' ? 'locale-btn--active' : ''}}"
        data-locale="en"
        bindtap="switchLocale"
      >EN</text>
    </view>
  </view>

  <!-- ====== 阅读提示 ====== -->
  <view class="section-block">
    <view class="section-label-row">
      <view class="section-label-dot"></view>
      <text class="section-label-text">{{t.layers.guide_label}}</text>
    </view>
    <view class="guide-cards">
      <view class="guide-card">
        <text class="guide-card-title">{{t.layers.guide_start_title}}</text>
        <text class="guide-card-desc">{{t.layers.guide_start_desc}}</text>
      </view>
      <view class="guide-card">
        <text class="guide-card-title">{{t.layers.guide_middle_title}}</text>
        <text class="guide-card-desc">{{t.layers.guide_middle_desc}}</text>
      </view>
      <view class="guide-card">
        <text class="guide-card-title">{{t.layers.guide_finish_title}}</text>
        <text class="guide-card-desc">{{t.layers.guide_finish_desc}}</text>
      </view>
    </view>
  </view>

  <!-- ====== 四个阶段 ====== -->
  <block wx:for="{{layerSections}}" wx:key="id">
    <view class="layer-block layer-block--{{item.id}}">

      <!-- 阶段头部 -->
      <view class="layer-header layer-header--{{item.id}}">
        <view class="layer-header-top">
          <view class="layer-index-badge layer-index-badge--{{item.id}}">
            <text class="layer-index-text">P{{item.index}}</text>
          </view>
          <view class="layer-header-info">
            <text class="layer-label">{{item.label}}</text>
            <view class="layer-progress-row">
              <text class="layer-progress-text">{{item.readCount}}/{{item.totalCount}}</text>
              <view class="layer-progress-bar">
                <view
                  class="layer-progress-fill layer-progress-fill--{{item.id}}"
                  style="width: {{item.totalCount > 0 ? (item.readCount / item.totalCount * 100) : 0}}%"
                ></view>
              </view>
            </view>
          </view>
        </view>
        <text class="layer-desc">{{item.desc}}</text>
        <view class="layer-outcome-row">
          <text class="layer-outcome-label">目标</text>
          <text class="layer-outcome-text">{{item.outcome}}</text>
        </view>
      </view>

      <!-- 阶段收口提示 -->
      <view class="checkpoint-block" wx:if="{{item.checkpoint}}">
        <view class="checkpoint-header" bindtap="toggleCheckpoint" data-id="{{item.id}}">
          <view class="checkpoint-header-left">
            <view class="checkpoint-tag checkpoint-tag--{{item.id}}">阶段收口</view>
            <text class="checkpoint-title">{{item.checkpoint.title}}</text>
          </view>
          <view class="checkpoint-toggle {{expandedCheckpoints[item.id] ? 'checkpoint-toggle--open' : ''}}">
            <text class="checkpoint-toggle-icon">▾</text>
          </view>
        </view>

        <view class="checkpoint-body">
          <!-- 入口 / 收口 跳转按钮 -->
          <view class="checkpoint-nav-row">
            <view class="checkpoint-nav-btn" bindtap="goToChapterEntry" data-id="{{item.checkpoint.entryVersion}}">
              <text class="checkpoint-nav-label">入口</text>
              <text class="checkpoint-nav-id">{{item.checkpoint.entryVersion}}</text>
            </view>
            <view class="checkpoint-nav-arrow">→</view>
            <view class="checkpoint-nav-btn" bindtap="goToChapterEntry" data-id="{{item.checkpoint.endVersion}}">
              <text class="checkpoint-nav-label">收口</text>
              <text class="checkpoint-nav-id">{{item.checkpoint.endVersion}}</text>
            </view>
          </view>

          <!-- 说明文字 -->
          <text class="checkpoint-body-text">{{item.checkpoint.body}}</text>

          <!-- 可折叠：重建目标 -->
          <view class="checkpoint-rebuild {{expandedCheckpoints[item.id] ? 'checkpoint-rebuild--visible' : ''}}" wx:if="{{expandedCheckpoints[item.id]}}">
            <view class="checkpoint-rebuild-label-row">
              <text class="checkpoint-rebuild-label">重建目标</text>
            </view>
            <text class="checkpoint-rebuild-text">{{item.checkpoint.rebuild}}</text>
          </view>
        </view>
      </view>

      <!-- 章节列表 -->
      <view class="versions-block">
        <view class="versions-list">
          <view
            class="version-item"
            wx:for="{{item.versions}}"
            wx:for-item="ver"
            wx:key="id"
            bindtap="goToChapter"
            data-id="{{ver.id}}"
          >
            <view class="version-left-bar version-left-bar--{{ver.layer}}"></view>
            <view class="version-content">
              <view class="version-top-row">
                <text class="version-id-tag">{{ver.id}}</text>
                <text class="version-title">{{ver.title}}</text>
                <view class="version-read-badge {{ver.isRead ? 'version-read-badge--read' : ''}}">
                  <text class="version-read-text">{{ver.isRead ? '✓' : ''}}</text>
                </view>
              </view>
              <text class="version-subtitle" wx:if="{{ver.subtitle}}">{{ver.subtitle}}</text>
              <view class="version-meta-row">
                <text class="version-loc">{{ver.loc}} 行</text>
                <text class="version-insight" wx:if="{{ver.keyInsight}}">{{ver.keyInsight}}</text>
              </view>
            </view>
            <view class="version-arrow">›</view>
          </view>
        </view>
      </view>

      <!-- 辅助文档 -->
      <view class="support-docs-block" wx:if="{{item.supportDocs.length > 0}}">
        <view class="support-docs-header">
          <view class="support-docs-icon">📚</view>
          <text class="support-docs-title">补课资料</text>
        </view>
        <view class="support-docs-list">
          <view
            class="support-doc-card"
            wx:for="{{item.supportDocs}}"
            wx:for-item="doc"
            wx:key="slug"
            bindtap="openBridgeDoc"
            data-slug="{{doc.slug}}"
          >
            <view class="support-doc-content">
              <text class="support-doc-title">{{doc.title}}</text>
              <text class="support-doc-summary" wx:if="{{doc.summary}}">{{doc.summary}}</text>
            </view>
            <text class="support-doc-arrow">›</text>
          </view>
        </view>
      </view>

    </view>
  </block>

  <!-- 底部间距 -->
  <view class="page-bottom"></view>

</scroll-view>

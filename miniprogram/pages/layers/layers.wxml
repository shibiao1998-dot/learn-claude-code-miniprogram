<!-- pages/layers/layers.wxml -->
<scroll-view scroll-y class="page">

  <!-- Page Header -->
  <view class="page-header">
    <view class="header-top">
      <text class="page-title">{{t_pageTitle}}</text>
      <view class="lang-switcher">
        <text class="lang-btn {{locale=='zh'?'active':''}}" bindtap="switchLocale" data-locale="zh">中</text>
        <text class="lang-btn {{locale=='en'?'active':''}}" bindtap="switchLocale" data-locale="en">EN</text>
      </view>
    </view>
    <text class="page-subtitle">{{t_pageSubtitle}}</text>
  </view>

  <!-- Layer Sections -->
  <view class="layers-content">
    <block wx:for="{{layerSections}}" wx:key="id">
      <view class="layer-section">
        <!-- Layer header with colored top border -->
        <view class="layer-section-header" style="border-top-color:{{item.cssColor}}">
          <view class="layer-section-top">
            <view class="layer-section-name">
              <text class="lsn-zh">{{item.label}}</text>
              <text class="lsn-en">{{item.id == 'core' ? 'Core' : item.id == 'hardening' ? 'Hardening' : item.id == 'runtime' ? 'Runtime' : 'Platform'}}</text>
            </view>
            <text class="layer-section-count {{item.readCount >= item.totalCount ? 'complete' : ''}}">{{item.readCount}}/{{item.totalCount}}</text>
          </view>
        </view>
        <text class="layer-section-desc">{{item.desc}}</text>

        <!-- Chapter rows -->
        <view class="layer-chapters">
          <view
            wx:for="{{item.versions}}"
            wx:for-item="v"
            wx:key="id"
            class="layer-chapter-row {{v.isRead ? 'read' : ''}}"
            bindtap="goToChapter"
            data-id="{{v.id}}"
            hover-class="row-hover"
          >
            <text class="lc-id">{{v.id}}</text>
            <text class="lc-title">{{v.title}}</text>
            <text class="lc-loc" wx:if="{{v.loc > 0}}">{{v.loc}} loc</text>
            <text class="lc-status" wx:if="{{v.isRead}}">✓</text>
          </view>
        </view>

        <!-- Checkpoint -->
        <view
          wx:if="{{item.checkpoint}}"
          class="checkpoint-row"
          bindtap="toggleCheckpoint"
          data-layer="{{item.id}}"
        >
          <view class="cp-header">
            <text class="cp-label">{{t_checkpointLabel}}</text>
            <text class="cp-toggle {{expandedCheckpoints[item.id] ? 'expanded' : ''}}">›</text>
          </view>
          <text class="cp-title">{{item.checkpoint.titleText}}</text>
          <view wx:if="{{expandedCheckpoints[item.id]}}" class="cp-body">
            <text class="cp-body-text">{{item.checkpoint.bodyText}}</text>
            <view class="cp-rebuild" wx:if="{{item.checkpoint.rebuildText}}">
              <text class="cp-rebuild-label">{{t_rebuildLabel}}</text>
              <text class="cp-rebuild-text">{{item.checkpoint.rebuildText}}</text>
            </view>
          </view>
        </view>
      </view>
    </block>
  </view>

  <view class="page-footer"></view>
</scroll-view>

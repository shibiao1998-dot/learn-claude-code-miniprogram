/* pages/layers/layers.wxss — V3 Design */

.page {
  height: 100vh;
  background: var(--color-bg);
}

/* ========== Page Header ========== */
.page-header {
  padding: 16rpx 40rpx 0;
  margin-bottom: 40rpx;
}

.header-top {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: baseline;
  margin-bottom: 8rpx;
}

.page-title {
  font-size: 48rpx;
  font-weight: 700;
  letter-spacing: -0.5rpx;
  line-height: 1.2;
  color: var(--color-text-primary);
}

.page-subtitle {
  display: block;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  line-height: 1.4;
}

/* Language Switcher */
.lang-switcher {
  display: flex;
  flex-direction: row;
  border: 2rpx solid var(--color-border);
  border-radius: 12rpx;
  overflow: hidden;
  flex-shrink: 0;
}

.lang-btn {
  font-size: 24rpx;
  font-weight: 500;
  color: var(--color-text-muted);
  padding: 8rpx 16rpx;
  border-right: 2rpx solid var(--color-border);
  line-height: 1;
}

.lang-btn:last-child {
  border-right: none;
}

.lang-btn.active {
  background: var(--color-text-primary);
  color: #FFFFFF;
  font-weight: 600;
}

/* ========== Layer Sections ========== */
.layers-content {
  padding: 0 40rpx;
}

.layer-section {
  margin-bottom: 56rpx;
}

.layer-section:last-child {
  margin-bottom: 0;
}

/* Layer header with colored top border */
.layer-section-header {
  border-top: 4rpx solid var(--color-border);
  padding-top: 28rpx;
  margin-bottom: 4rpx;
}

.layer-section-top {
  display: flex;
  flex-direction: row;
  align-items: baseline;
  justify-content: space-between;
}

.layer-section-name {
  display: flex;
  flex-direction: row;
  align-items: baseline;
  gap: 16rpx;
}

.lsn-zh {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.lsn-en {
  font-size: 26rpx;
  font-weight: 400;
  color: var(--color-text-muted);
}

.layer-section-count {
  font-size: 24rpx;
  font-weight: 500;
  color: var(--color-text-muted);
  font-variant: tabular-nums;
}

.layer-section-count.complete {
  color: var(--color-core);
}

.layer-section-desc {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-muted);
  line-height: 1.4;
  margin-bottom: 28rpx;
}

/* ========== Chapter Rows ========== */
.layer-chapters {
  margin-bottom: 20rpx;
}

.layer-chapter-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--color-bg-card);
}

.layer-chapter-row:last-child {
  border-bottom: none;
}

.row-hover {
  opacity: 0.6;
}

.lc-id {
  font-family: 'SF Mono', 'Menlo', monospace;
  font-size: 22rpx;
  font-weight: 500;
  color: var(--color-text-muted);
  width: 56rpx;
  flex-shrink: 0;
}

.lc-title {
  font-size: 28rpx;
  font-weight: 400;
  color: var(--color-text-primary);
  flex: 1;
}

.lc-loc {
  font-size: 22rpx;
  font-weight: 400;
  color: var(--color-text-faint);
  font-family: 'SF Mono', 'Menlo', monospace;
  font-variant: tabular-nums;
  margin-right: 20rpx;
}

.lc-status {
  font-size: 24rpx;
  color: var(--color-core);
  width: 32rpx;
  text-align: center;
  flex-shrink: 0;
}

/* Read state */
.layer-chapter-row.read .lc-title {
  color: var(--color-text-muted);
}

.layer-chapter-row.read .lc-id {
  color: var(--color-text-faint);
}

/* ========== Checkpoint ========== */
.checkpoint-row {
  background: var(--color-bg-card);
  border-radius: 12rpx;
  padding: 24rpx;
}

.cp-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.cp-label {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--color-text-secondary);
}

.cp-toggle {
  font-size: 28rpx;
  color: var(--color-text-muted);
  transition: transform 0.2s;
}

.cp-toggle.expanded {
  transform: rotate(90deg);
}

.cp-title {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-muted);
  line-height: 1.5;
}

.cp-body {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid var(--color-border);
}

.cp-body-text {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  line-height: 1.6;
  margin-bottom: 16rpx;
}

.cp-rebuild {
  background: var(--color-bg);
  border-radius: 8rpx;
  padding: 16rpx 20rpx;
}

.cp-rebuild-label {
  display: block;
  font-size: 22rpx;
  color: var(--color-text-muted);
  margin-bottom: 4rpx;
}

.cp-rebuild-text {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  line-height: 1.6;
}

/* ========== Footer ========== */
.page-footer {
  height: 80rpx;
}

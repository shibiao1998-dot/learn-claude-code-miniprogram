/* pages/layers/layers.wxss */

/* ====== 整体滚动容器 ====== */
.page-scroll {
  height: 100vh;
  background-color: var(--color-bg);
}

/* ====== 头部 ====== */
.page-header {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  justify-content: space-between;
  padding: var(--spacing-xl) var(--spacing-md) var(--spacing-md);
  background: linear-gradient(180deg, #EFF6FF 0%, var(--color-bg) 100%);
}

.header-content {
  flex: 1;
  margin-right: var(--spacing-sm);
}

.header-title {
  display: block;
  font-size: var(--font-xl);
  font-weight: 700;
  color: var(--color-text-primary);
  line-height: 1.3;
  margin-bottom: var(--spacing-xs);
}

.header-subtitle {
  display: block;
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
  line-height: 1.6;
}

/* 语言切换 */
.locale-switcher {
  display: flex;
  flex-direction: row;
  gap: var(--spacing-xs);
  margin-top: 6rpx;
  flex-shrink: 0;
}

.locale-btn {
  padding: 6rpx 16rpx;
  border-radius: var(--radius-sm);
  font-size: var(--font-xs);
  color: var(--color-text-muted);
  border: 1rpx solid var(--color-border);
  background: transparent;
}

.locale-btn--active {
  color: var(--color-accent);
  border-color: var(--color-accent);
  background: rgba(2, 132, 199, 0.1);
}

/* ====== 通用区块 ====== */
.section-block {
  padding: var(--spacing-md) var(--spacing-md) 0;
}

.section-label-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: var(--spacing-sm);
  gap: var(--spacing-xs);
}

.section-label-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: var(--color-accent);
  flex-shrink: 0;
}

.section-label-text {
  font-size: var(--font-xs);
  color: var(--color-accent);
  font-weight: 600;
  letter-spacing: 1rpx;
}

/* ====== 阅读提示卡片 ====== */
.guide-cards {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-xs);
}

.guide-card {
  background: var(--color-bg-card);
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-md);
  padding: var(--spacing-sm) var(--spacing-md);
}

.guide-card-title {
  display: block;
  font-size: var(--font-sm);
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 6rpx;
}

.guide-card-desc {
  display: block;
  font-size: var(--font-xs);
  color: var(--color-text-secondary);
  line-height: 1.6;
}

/* ====== 阶段大卡块 ====== */
.layer-block {
  margin: var(--spacing-md) var(--spacing-md) 0;
  border-radius: var(--radius-lg);
  overflow: hidden;
  border: 1rpx solid var(--color-border);
}

/* 左侧彩色边框 */
.layer-block--core      { border-left: 6rpx solid var(--color-core); }
.layer-block--hardening { border-left: 6rpx solid var(--color-hardening); }
.layer-block--runtime   { border-left: 6rpx solid var(--color-runtime); }
.layer-block--platform  { border-left: 6rpx solid var(--color-platform); }

/* ====== 阶段头部 ====== */
.layer-header {
  padding: var(--spacing-md);
}

.layer-header--core     { background: linear-gradient(135deg, rgba(5,150,105,0.15) 0%, rgba(5,150,105,0.04) 100%); }
.layer-header--hardening { background: linear-gradient(135deg, rgba(37,99,235,0.15) 0%, rgba(37,99,235,0.04) 100%); }
.layer-header--runtime  { background: linear-gradient(135deg, rgba(124,58,237,0.15) 0%, rgba(124,58,237,0.04) 100%); }
.layer-header--platform { background: linear-gradient(135deg, rgba(219,39,119,0.15) 0%, rgba(219,39,119,0.04) 100%); }

.layer-header-top {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: var(--spacing-sm);
  gap: var(--spacing-sm);
}

/* P1/P2/P3/P4 序号徽章 */
.layer-index-badge {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.layer-index-badge--core     { background: rgba(5,150,105,0.2); }
.layer-index-badge--hardening { background: rgba(37,99,235,0.2); }
.layer-index-badge--runtime  { background: rgba(124,58,237,0.2); }
.layer-index-badge--platform { background: rgba(219,39,119,0.2); }

.layer-index-text {
  font-size: var(--font-sm);
  font-weight: 700;
  color: var(--color-text-primary);
}

.layer-header-info {
  flex: 1;
  min-width: 0;
}

.layer-label {
  display: block;
  font-size: var(--font-md);
  font-weight: 700;
  color: var(--color-text-primary);
  margin-bottom: 6rpx;
}

.layer-progress-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: var(--spacing-xs);
}

.layer-progress-text {
  font-size: var(--font-xs);
  color: var(--color-text-muted);
  flex-shrink: 0;
}

.layer-progress-bar {
  flex: 1;
  height: 6rpx;
  background: var(--color-bg-muted);
  border-radius: 3rpx;
  overflow: hidden;
}

.layer-progress-fill {
  height: 100%;
  border-radius: 3rpx;
}

.layer-progress-fill--core     { background: var(--color-core); }
.layer-progress-fill--hardening { background: var(--color-hardening); }
.layer-progress-fill--runtime  { background: var(--color-runtime); }
.layer-progress-fill--platform { background: var(--color-platform); }

.layer-desc {
  display: block;
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
  line-height: 1.65;
  margin-bottom: var(--spacing-sm);
}

.layer-outcome-row {
  display: flex;
  flex-direction: row;
  gap: var(--spacing-xs);
  background: rgba(0,0,0,0.05);
  border-radius: var(--radius-sm);
  padding: var(--spacing-xs) var(--spacing-sm);
}

.layer-outcome-label {
  font-size: var(--font-xs);
  color: var(--color-text-muted);
  flex-shrink: 0;
  padding-top: 2rpx;
}

.layer-outcome-text {
  font-size: var(--font-xs);
  color: var(--color-text-secondary);
  line-height: 1.6;
  flex: 1;
}

/* ====== 阶段收口 Checkpoint ====== */
.checkpoint-block {
  background: var(--color-bg-card);
  border-top: 1rpx solid var(--color-border);
  padding: var(--spacing-sm) var(--spacing-md);
}

.checkpoint-header {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  justify-content: space-between;
  gap: var(--spacing-xs);
}

.checkpoint-header-left {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.checkpoint-tag {
  display: inline-block;
  font-size: var(--font-xs);
  font-weight: 600;
  padding: 2rpx 12rpx;
  border-radius: 6rpx;
  align-self: flex-start;
}

.checkpoint-tag--core     { background: rgba(5,150,105,0.15); color: var(--color-core); }
.checkpoint-tag--hardening { background: rgba(37,99,235,0.15); color: var(--color-hardening); }
.checkpoint-tag--runtime  { background: rgba(124,58,237,0.15); color: var(--color-runtime); }
.checkpoint-tag--platform { background: rgba(219,39,119,0.15); color: var(--color-platform); }

.checkpoint-title {
  font-size: var(--font-sm);
  font-weight: 600;
  color: var(--color-text-primary);
  line-height: 1.5;
}

.checkpoint-toggle {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.checkpoint-toggle-icon {
  font-size: 32rpx;
  color: var(--color-text-muted);
  display: block;
}

.checkpoint-toggle--open .checkpoint-toggle-icon {
  transform: rotate(180deg);
}

.checkpoint-body {
  margin-top: var(--spacing-sm);
}

.checkpoint-nav-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: var(--spacing-xs);
  margin-bottom: var(--spacing-sm);
}

.checkpoint-nav-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: var(--color-bg-muted);
  border-radius: var(--radius-sm);
  padding: 8rpx 24rpx;
  gap: 2rpx;
}

.checkpoint-nav-label {
  font-size: var(--font-xs);
  color: var(--color-text-muted);
}

.checkpoint-nav-id {
  font-size: var(--font-sm);
  font-weight: 700;
  color: var(--color-accent);
  font-family: monospace;
}

.checkpoint-nav-arrow {
  font-size: var(--font-sm);
  color: var(--color-text-muted);
  flex-shrink: 0;
}

.checkpoint-body-text {
  display: block;
  font-size: var(--font-xs);
  color: var(--color-text-secondary);
  line-height: 1.7;
  margin-bottom: var(--spacing-xs);
}

/* 折叠展开：重建目标 */
.checkpoint-rebuild {
  background: rgba(0,0,0,0.05);
  border-radius: var(--radius-sm);
  padding: var(--spacing-sm);
  margin-top: var(--spacing-xs);
  border-left: 3rpx solid var(--color-accent);
}

.checkpoint-rebuild-label-row {
  margin-bottom: 6rpx;
}

.checkpoint-rebuild-label {
  font-size: var(--font-xs);
  color: var(--color-accent);
  font-weight: 600;
}

.checkpoint-rebuild-text {
  display: block;
  font-size: var(--font-xs);
  color: var(--color-text-secondary);
  line-height: 1.7;
}

/* ====== 章节列表 ====== */
.versions-block {
  background: var(--color-bg);
  border-top: 1rpx solid var(--color-border);
}

.versions-list {
  display: flex;
  flex-direction: column;
}

.version-item {
  display: flex;
  flex-direction: row;
  align-items: stretch;
  border-bottom: 1rpx solid var(--color-border);
  background: var(--color-bg-card);
  padding: var(--spacing-sm) var(--spacing-sm) var(--spacing-sm) 0;
  overflow: hidden;
}

.version-item:last-child {
  border-bottom: none;
}

/* 左侧彩色条 */
.version-left-bar {
  width: 4rpx;
  flex-shrink: 0;
  margin-right: var(--spacing-sm);
  border-radius: 2rpx;
  align-self: stretch;
}

.version-left-bar--core     { background: var(--color-core); }
.version-left-bar--hardening { background: var(--color-hardening); }
.version-left-bar--runtime  { background: var(--color-runtime); }
.version-left-bar--platform { background: var(--color-platform); }

.version-content {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.version-top-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: var(--spacing-xs);
}

.version-id-tag {
  font-size: var(--font-xs);
  font-weight: 700;
  color: var(--color-text-muted);
  font-family: monospace;
  background: var(--color-bg-muted);
  padding: 2rpx 10rpx;
  border-radius: 4rpx;
  flex-shrink: 0;
}

.version-title {
  font-size: var(--font-sm);
  font-weight: 600;
  color: var(--color-text-primary);
  flex: 1;
  min-width: 0;
}

.version-read-badge {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  border: 2rpx solid var(--color-border);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.version-read-badge--read {
  background: var(--color-core);
  border-color: var(--color-core);
}

.version-read-text {
  font-size: 18rpx;
  color: var(--color-bg);
  font-weight: 700;
}

.version-subtitle {
  font-size: var(--font-xs);
  color: var(--color-text-muted);
  line-height: 1.4;
}

.version-meta-row {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  gap: var(--spacing-sm);
  flex-wrap: wrap;
  margin-top: 2rpx;
}

.version-loc {
  font-size: var(--font-xs);
  color: var(--color-text-muted);
  flex-shrink: 0;
  font-family: monospace;
}

.version-insight {
  font-size: var(--font-xs);
  color: var(--color-text-secondary);
  line-height: 1.5;
  flex: 1;
  min-width: 0;
}

.version-arrow {
  font-size: var(--font-md);
  color: var(--color-text-muted);
  display: flex;
  align-items: center;
  padding-left: var(--spacing-xs);
  align-self: center;
  flex-shrink: 0;
}

/* ====== 辅助文档 ====== */
.support-docs-block {
  background: var(--color-bg-card);
  border-top: 1rpx solid var(--color-border);
  padding: var(--spacing-sm) var(--spacing-md);
}

.support-docs-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: var(--spacing-xs);
  margin-bottom: var(--spacing-sm);
}

.support-docs-icon {
  font-size: var(--font-base);
}

.support-docs-title {
  font-size: var(--font-sm);
  font-weight: 600;
  color: var(--color-text-secondary);
}

.support-docs-list {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-xs);
}

.support-doc-card {
  display: flex;
  flex-direction: row;
  align-items: center;
  background: var(--color-bg-muted);
  border-radius: var(--radius-sm);
  padding: var(--spacing-xs) var(--spacing-sm);
  gap: var(--spacing-xs);
}

.support-doc-content {
  flex: 1;
  min-width: 0;
}

.support-doc-title {
  display: block;
  font-size: var(--font-sm);
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 4rpx;
}

.support-doc-summary {
  display: block;
  font-size: var(--font-xs);
  color: var(--color-text-muted);
  line-height: 1.5;
}

.support-doc-arrow {
  font-size: var(--font-md);
  color: var(--color-accent);
  flex-shrink: 0;
}

/* ====== 底部间距 ====== */
.page-bottom {
  height: var(--spacing-xl);
}

<!-- pages/timeline/timeline.wxml -->
<scroll-view scroll-y class="page">

  <!-- Page Header -->
  <view class="page-header">
    <view class="header-top">
      <text class="page-title">{{pageTitle}}</text>
      <view class="lang-switcher">
        <text class="lang-btn {{locale=='zh'?'active':''}}" bindtap="switchLocale" data-locale="zh">中</text>
        <text class="lang-btn {{locale=='en'?'active':''}}" bindtap="switchLocale" data-locale="en">EN</text>
        <text class="lang-btn {{locale=='ja'?'active':''}}" bindtap="switchLocale" data-locale="ja">日</text>
      </view>
    </view>
    <text class="page-subtitle">{{pageSubtitle}}</text>
    <view class="progress-strip">
      <view class="bar-track">
        <view class="bar-fill" style="width:{{readCount / totalChapters * 100}}%"></view>
      </view>
      <text class="bar-label">{{readCount}} / {{totalChapters}}</text>
    </view>
  </view>

  <!-- Metro Timeline -->
  <view class="metro-timeline">
    <block wx:for="{{timelineItems}}" wx:key="id">

      <!-- Layer connector (between layer sections, not for first layer-start) -->
      <view wx:if="{{item.isLayerStart && index > 0}}" class="metro-connector">
        <view class="connector-top" style="background:{{item.prevLayerColor}}"></view>
        <view class="connector-bottom" style="background:{{item.layerColor}}"></view>
      </view>

      <!-- Transfer station (layer boundary) -->
      <view wx:if="{{item.isLayerStart}}" class="metro-transfer">
        <!-- Rail line behind transfer -->
        <view class="metro-rail" style="background:{{item.layerColor}}"></view>
        <!-- Transfer node (ring + dot) -->
        <view class="transfer-node" style="border-color:{{item.layerColor}}">
          <view class="transfer-dot" style="background:{{item.layerColor}}"></view>
        </view>
        <view class="transfer-info">
          <text class="transfer-name">{{item.layerLabel}}</text>
          <text class="transfer-range">{{item.rangeText}}</text>
        </view>
      </view>

      <!-- Regular station -->
      <view
        class="metro-station {{item.isRead ? 'read' : ''}} {{item.isCurrent ? 'current' : ''}} {{!item.isRead && !item.isCurrent ? 'future' : ''}}"
        bindtap="goToChapter"
        data-id="{{item.id}}"
        hover-class="station-hover"
      >
        <!-- Rail line behind station -->
        <view class="metro-rail {{item.isLast ? 'metro-rail-last' : ''}}" style="background:{{item.layerColor}}"></view>
        <!-- Station dot -->
        <view class="station-dot-wrap">
          <view class="station-dot" style="background:{{item.layerColor}}"></view>
        </view>
        <!-- Station text -->
        <view class="station-text">
          <text class="station-id">{{item.id}}</text>
          <text class="station-title">{{item.title}}</text>
        </view>
        <text wx:if="{{item.isRead}}" class="station-check">✓</text>
        <text wx:elif="{{item.isCurrent}}" class="station-current-label">{{t_currentLabel || '当前'}}</text>
      </view>

    </block>
  </view>

  <!-- Bridge Docs -->
  <view class="bridge-section" wx:if="{{bridgeLinks.length > 0}}">
    <text class="bridge-title">Bridge Docs</text>
    <view class="bridge-list">
      <text
        wx:for="{{bridgeLinks}}"
        wx:key="slug"
        class="bridge-link"
        bindtap="openBridgeDoc"
        data-slug="{{item.slug}}"
      >{{item.label}}</text>
    </view>
  </view>

  <view class="page-footer"></view>
</scroll-view>

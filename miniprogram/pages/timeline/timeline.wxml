<!-- pages/timeline/timeline.wxml -->
<scroll-view class="page" scroll-y enhanced show-scrollbar="{{false}}">

  <!-- ========== 头部 ========== -->
  <view class="page-header">
    <view class="header-content">
      <text class="page-title">{{pageTitle}}</text>
      <text class="page-subtitle">{{pageSubtitle}}</text>
    </view>

    <!-- 语言切换 -->
    <view class="locale-switcher">
      <view
        wx:for="{{['zh','en','ja']}}"
        wx:key="*this"
        class="locale-btn {{locale === item ? 'active' : ''}}"
        bindtap="switchLocale"
        data-locale="{{item}}"
      >
        <text>{{item}}</text>
      </view>
    </view>

    <!-- 阅读进度 -->
    <view class="progress-row">
      <view class="progress-bar-bg">
        <view class="progress-bar-fill" style="width: {{totalChapters > 0 ? readCount / totalChapters * 100 : 0}}%"></view>
      </view>
      <text class="progress-text">{{t_readCountLabel}} {{readCount}} / {{totalChapters}} {{t_chaptersUnit}}</text>
    </view>

    <!-- 桥接文档快速入口（紧凑） -->
    <view class="bridge-pills">
      <view
        wx:for="{{bridgeLinks}}"
        wx:key="slug"
        class="bridge-pill"
        bindtap="openBridgeDoc"
        data-slug="{{item.slug}}"
      >
        <text>{{item.label}}</text>
      </view>
    </view>
  </view>

  <!-- ========== 阶段检查点（紧凑） ========== -->
  <view class="section">
    <text class="section-title">{{t_checkpointSectionTitle}}</text>

    <view class="checkpoint-cards">
      <view
        wx:for="{{checkpoints}}"
        wx:key="layer"
        class="checkpoint-card card"
        style="border-left-color: {{item.layerColor}}"
      >
        <!-- 检查点头部 -->
        <view class="checkpoint-header" bindtap="toggleCheckpoint" data-layer="{{item.layer}}">
          <view class="checkpoint-layer-badge" style="background: {{item.layerColor}}20; border-color: {{item.layerColor}}40">
            <view class="checkpoint-layer-dot" style="background: {{item.layerColor}}"></view>
            <text class="checkpoint-layer-label" style="color: {{item.layerColor}}">{{item.layerLabel}}</text>
          </view>
          <view class="checkpoint-range">
            <text class="checkpoint-range-text">{{item.entryVersion}} → {{item.endVersion}}</text>
          </view>
          <view class="checkpoint-toggle-icon {{expandedCheckpoints[item.layer] ? 'expanded' : ''}}">
            <text>›</text>
          </view>
        </view>

        <!-- 检查点标题 -->
        <text class="checkpoint-title">{{item.titleText}}</text>

        <!-- 可折叠：重建目标 -->
        <view wx:if="{{expandedCheckpoints[item.layer]}}" class="checkpoint-body">
          <text class="checkpoint-body-text">{{item.bodyText}}</text>
          <view class="checkpoint-rebuild">
            <text class="checkpoint-rebuild-label">{{t_checkpointRebuildLabel}}</text>
            <text class="checkpoint-rebuild-text">{{item.rebuildText}}</text>
          </view>
        </view>

        <!-- 折叠时显示提示 -->
        <view wx:else class="checkpoint-collapsed-hint" bindtap="toggleCheckpoint" data-layer="{{item.layer}}">
          <text class="checkpoint-hint-text">{{t_checkpointToggleShow}}</text>
          <text class="checkpoint-hint-arrow">›</text>
        </view>
      </view>
    </view>
  </view>

  <!-- ========== 主时间线（地铁线路图） ========== -->
  <view class="section section-last">
    <text class="section-title">{{t_timelineSectionTitle}}</text>

    <view class="metro-line">
      <block wx:for="{{timelineItems}}" wx:key="id">

        <!-- 换乘站（阶段起始） -->
        <view wx:if="{{item.isLayerStart}}" class="metro-transfer"
              bindtap="toggleCheckpoint" data-layer="{{item.layer}}">
          <!-- 第一个换乘站不画上方轨道 -->
          <view wx:if="{{index > 0}}" class="metro-rail metro-rail-transfer" style="background: {{item.layerColor}}"></view>
          <view wx:else class="metro-rail metro-rail-transfer metro-rail-first" style="background: {{item.layerColor}}"></view>
          <view class="transfer-node" style="border-color: {{item.layerColor}}">
            <view class="transfer-dot" style="background: {{item.layerColor}}"></view>
          </view>
          <view class="transfer-text">
            <text class="transfer-label" style="color: {{item.layerColor}}">{{item.layerLabel}}</text>
            <text class="transfer-range">{{item.rangeText}}</text>
          </view>
        </view>

        <!-- 普通站点（所有章节都渲染，包括换乘站章节） -->
        <view class="metro-station {{item.isRead ? 'read' : ''}}"
              bindtap="goToChapter" data-id="{{item.id}}"
              hover-class="station-hover">
          <view class="metro-rail" style="background: {{item.layerColor}}"></view>
          <view class="station-dot" style="background: {{item.layerColor}}"></view>
          <text class="station-id" style="color: {{item.layerColor}}">{{item.id}}</text>
          <text class="station-name">{{item.title}}</text>
        </view>

      </block>

      <!-- 终点标记 -->
      <view class="metro-end">
        <view class="metro-rail metro-rail-end" style="background: {{lastLayerColor}}"></view>
        <view class="end-dot" style="background: {{lastLayerColor}}"></view>
      </view>
    </view>
  </view>

  <!-- 底部留白 -->
  <view class="page-footer"></view>

</scroll-view>

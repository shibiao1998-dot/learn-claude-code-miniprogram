/* pages/timeline/timeline.wxss */

/* ========== 页面容器 ========== */
.page {
  height: 100vh;
  background: var(--color-bg);
}

/* ========== 页头 ========== */
.page-header {
  padding: var(--spacing-xl) var(--spacing-lg) var(--spacing-md);
  background: var(--color-bg-card);
  border-bottom: 1rpx solid var(--color-border);
}

.header-content {
  margin-bottom: var(--spacing-md);
}

.page-title {
  display: block;
  font-size: var(--font-2xl);
  font-weight: 700;
  color: var(--color-text-primary);
  line-height: 1.2;
  margin-bottom: var(--spacing-xs);
}

.page-subtitle {
  display: block;
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
  line-height: 1.6;
}

/* 语言切换 */
.locale-switcher {
  display: flex;
  flex-direction: row;
  margin-bottom: var(--spacing-md);
}

.locale-btn {
  padding: var(--spacing-xs) var(--spacing-sm);
  margin-right: var(--spacing-xs);
  border-radius: var(--radius-sm);
  background: var(--color-bg-muted);
  font-size: var(--font-xs);
  color: var(--color-text-muted);
}

.locale-btn.active {
  background: var(--color-accent);
  color: #0F172A;
  font-weight: 600;
}

/* 进度条 */
.progress-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: var(--spacing-sm);
}

.progress-bar-bg {
  flex: 1;
  height: 6rpx;
  background: var(--color-bg-muted);
  border-radius: 3rpx;
  overflow: hidden;
}

.progress-bar-fill {
  height: 100%;
  background: var(--color-accent);
  border-radius: 3rpx;
  transition: width 0.3s;
}

.progress-text {
  font-size: var(--font-xs);
  color: var(--color-text-muted);
  white-space: nowrap;
}

/* ========== 通用 section ========== */
.section {
  padding: var(--spacing-lg) var(--spacing-lg) 0;
}

.section-last {
  padding-bottom: 0;
}

.section-title {
  display: block;
  font-size: var(--font-md);
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: var(--spacing-xs);
}

.section-desc {
  display: block;
  font-size: var(--font-xs);
  color: var(--color-text-muted);
  line-height: 1.5;
  margin-bottom: var(--spacing-md);
}

/* ========== 通用卡片 ========== */
.card {
  background: var(--color-bg-card);
  border-radius: var(--radius-md);
  border: 1rpx solid var(--color-border);
  padding: var(--spacing-md);
}

/* ========== 使用指南卡片 ========== */
.guide-cards {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-sm);
  margin-bottom: var(--spacing-md);
}

.guide-card {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.guide-icon {
  font-size: var(--font-lg);
  margin-bottom: 4rpx;
}

.guide-card-title {
  font-size: var(--font-base);
  font-weight: 600;
  color: var(--color-text-primary);
}

.guide-card-desc {
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
  line-height: 1.6;
}

/* ========== 桥接文档 pills ========== */
.bridge-pills {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: var(--spacing-xs);
  margin-bottom: var(--spacing-md);
}

.bridge-pill {
  padding: var(--spacing-xs) var(--spacing-sm);
  background: var(--color-bg-muted);
  border-radius: 100rpx;
  border: 1rpx solid var(--color-border);
}

.bridge-pill text {
  font-size: var(--font-xs);
  color: var(--color-accent);
}

/* ========== 阶段检查点卡片 ========== */
.checkpoint-cards {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-sm);
  margin-bottom: var(--spacing-md);
}

.checkpoint-card {
  border-left: 4rpx solid transparent;
  padding-left: var(--spacing-md);
}

.checkpoint-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: var(--spacing-xs);
  gap: var(--spacing-xs);
}

.checkpoint-layer-badge {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 4rpx 12rpx;
  border-radius: 100rpx;
  border: 1rpx solid transparent;
  gap: var(--spacing-xs);
}

.checkpoint-layer-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  display: block;
  flex-shrink: 0;
}

.checkpoint-layer-label {
  font-size: var(--font-xs);
  font-weight: 600;
}

.checkpoint-range {
  flex: 1;
}

.checkpoint-range-text {
  font-size: var(--font-xs);
  color: var(--color-text-muted);
  font-family: monospace;
}

.checkpoint-toggle-icon {
  font-size: 36rpx;
  color: var(--color-text-muted);
  line-height: 1;
  transition: transform 0.2s;
}

.checkpoint-toggle-icon.expanded {
  transform: rotate(90deg);
}

.checkpoint-title {
  display: block;
  font-size: var(--font-sm);
  font-weight: 600;
  color: var(--color-text-primary);
  line-height: 1.5;
  margin-bottom: var(--spacing-xs);
}

.checkpoint-body {
  margin-top: var(--spacing-xs);
}

.checkpoint-body-text {
  display: block;
  font-size: var(--font-xs);
  color: var(--color-text-secondary);
  line-height: 1.6;
  margin-bottom: var(--spacing-sm);
}

.checkpoint-rebuild {
  background: var(--color-bg-muted);
  border-radius: var(--radius-sm);
  padding: var(--spacing-sm) var(--spacing-md);
}

.checkpoint-rebuild-label {
  display: block;
  font-size: var(--font-xs);
  color: var(--color-text-muted);
  margin-bottom: 4rpx;
}

.checkpoint-rebuild-text {
  display: block;
  font-size: var(--font-xs);
  color: var(--color-text-secondary);
  line-height: 1.6;
}

.checkpoint-collapsed-hint {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 4rpx;
}

.checkpoint-hint-text {
  font-size: var(--font-xs);
  color: var(--color-text-muted);
}

.checkpoint-hint-arrow {
  font-size: var(--font-xs);
  color: var(--color-text-muted);
}

/* ========== 地铁线路图 ========== */
.metro-line {
  position: relative;
  padding: var(--spacing-sm) 0 var(--spacing-lg);
}

/* ---- 连续轨道线 ---- */
.metro-rail {
  position: absolute;
  left: 45rpx;
  top: 0;
  bottom: 0;
  width: 6rpx;
  border-radius: 3rpx;
}

/* 换乘站的轨道 */
.metro-rail-transfer {
  top: 0;
  bottom: 0;
}

/* 终点段的轨道：只到圆点中心位置 */
.metro-rail-end {
  bottom: auto;
  height: 24rpx;
}

/* ---- 普通站点行 ---- */
.metro-station {
  position: relative;
  display: flex;
  flex-direction: row;
  align-items: center;
  height: 80rpx;
  padding-left: 80rpx;
}

.metro-station.read .station-dot {
  opacity: 0.4;
}

.metro-station.read .station-id,
.metro-station.read .station-name {
  opacity: 0.4;
}

.station-hover {
  background: rgba(51, 65, 85, 0.3);
  border-radius: var(--radius-sm);
}

.station-dot {
  position: absolute;
  left: 40rpx;
  top: 50%;
  width: 16rpx;
  height: 16rpx;
  margin-top: -8rpx;
  border-radius: 50%;
}

.station-id {
  font-size: var(--font-xs);
  font-weight: 700;
  font-family: monospace;
  width: 60rpx;
  flex-shrink: 0;
}

.station-name {
  font-size: var(--font-sm);
  color: var(--color-text-primary);
  margin-left: var(--spacing-sm);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* ---- 换乘站行 ---- */
.metro-transfer {
  position: relative;
  display: flex;
  flex-direction: row;
  align-items: center;
  height: 120rpx;
  padding-left: 80rpx;
  margin-top: 20rpx;
  margin-bottom: 20rpx;
}

/* 第一个换乘站不需要顶部额外间距 */
.metro-transfer:first-child {
  margin-top: 0;
}

.transfer-node {
  position: absolute;
  left: 32rpx;
  top: 50%;
  width: 32rpx;
  height: 32rpx;
  margin-top: -16rpx;
  border-radius: 50%;
  border: 4rpx solid;
  background: var(--color-bg);
  display: flex;
  align-items: center;
  justify-content: center;
}

.transfer-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
}

.transfer-text {
  display: flex;
  flex-direction: row;
  align-items: baseline;
  gap: var(--spacing-sm);
}

.transfer-label {
  font-size: var(--font-sm);
  font-weight: 700;
  letter-spacing: 1rpx;
}

.transfer-range {
  font-size: var(--font-xs);
  color: var(--color-text-muted);
  font-family: monospace;
}

/* ---- 终点标记 ---- */
.metro-end {
  position: relative;
  height: 32rpx;
}

.end-dot {
  position: absolute;
  left: 44rpx;
  top: 24rpx;
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  opacity: 0.5;
}

/* ========== 底部留白 ========== */
.page-footer {
  height: 80rpx;
}

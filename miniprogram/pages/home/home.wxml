<!-- pages/home/home.wxml -->
<scroll-view scroll-y class="page">

  <!-- Page Header -->
  <view class="page-header">
    <view class="header-top">
      <text class="page-title">Learn Claude Code</text>
      <view class="lang-switcher">
        <text class="lang-btn {{locale=='zh'?'active':''}}" bindtap="switchLocale" data-locale="zh">中</text>
        <text class="lang-btn {{locale=='en'?'active':''}}" bindtap="switchLocale" data-locale="en">EN</text>
        <text class="lang-btn {{locale=='ja'?'active':''}}" bindtap="switchLocale" data-locale="ja">日</text>
      </view>
    </view>
    <text class="page-subtitle">{{t.home.hero_subtitle}}</text>
  </view>

  <!-- Progress Strip -->
  <view class="progress-strip" wx:if="{{readCount > 0}}">
    <view class="bar-track">
      <view class="bar-fill" style="width:{{readCount / totalCount * 100}}%"></view>
    </view>
    <text class="bar-label">{{readCount}} / {{totalCount}} {{t.home.chapters_unit || '章'}}</text>
  </view>

  <!-- Quick Entry Grid -->
  <view class="quick-grid">
    <view class="quick-card" bindtap="goToStart">
      <text class="qc-title">{{t.home.entry_start_title || '从最小闭环开始'}}</text>
      <text class="qc-desc">{{t.home.entry_start_desc || '继续学习'}}</text>
    </view>
    <view class="quick-card" bindtap="goToTimeline">
      <text class="qc-title">{{t.home.entry_timeline_title || '学习时间线'}}</text>
      <text class="qc-desc">{{t.home.entry_timeline_desc || '路径总览'}}</text>
    </view>
    <view class="quick-card" bindtap="goToLayers">
      <text class="qc-title">{{t.home.entry_layers_title || '架构层总览'}}</text>
      <text class="qc-desc">{{t.home.entry_layers_desc || '四层结构'}}</text>
    </view>
    <view class="quick-card" bindtap="goToCompare">
      <text class="qc-title">{{t.home.entry_compare_title || '版本对比'}}</text>
      <text class="qc-desc">{{t.home.entry_compare_desc || '差异分析'}}</text>
    </view>
  </view>

  <!-- Chapter List by Layer -->
  <view class="chapters-section">
    <block wx:for="{{layers}}" wx:key="id">
      <view class="layer-group">
        <!-- Layer Header -->
        <view class="layer-header">
          <view class="layer-header-left">
            <view class="layer-dot" style="background:{{item.color}}"></view>
            <text class="layer-name">{{item.label}}</text>
            <text class="layer-name-en">{{item.id == 'core' ? 'Core' : item.id == 'hardening' ? 'Hardening' : item.id == 'runtime' ? 'Runtime' : 'Platform'}}</text>
          </view>
          <text class="layer-count {{item.readCount >= item.versions.length ? 'complete' : ''}}">{{item.readCount || 0}}/{{item.versions.length}}</text>
        </view>

        <!-- Chapter Rows with colored left border -->
        <view class="chapter-list" style="border-left-color:{{item.color}}">
          <view
            wx:for="{{item.versions}}"
            wx:for-item="chapter"
            wx:key="id"
            class="chapter-row {{chapter.isRead ? 'read' : ''}} {{chapter.isNext ? 'next' : ''}}"
            bindtap="goToChapter"
            data-id="{{chapter.id}}"
            hover-class="chapter-hover"
          >
            <text class="ch-id">{{chapter.id}}</text>
            <text class="ch-title">{{chapter.title}}</text>
            <text class="ch-status" wx:if="{{chapter.isRead}}">✓</text>
            <text class="ch-arrow" wx:elif="{{chapter.isNext}}">›</text>
          </view>
        </view>
      </view>
    </block>
  </view>

  <view class="page-footer"></view>
</scroll-view>

<!-- pages/home/home.wxml -->
<scroll-view scroll-y class="page">

  <!-- ======= Hero 区域 ======= -->
  <view class="hero">
    <view class="hero-badge">
      <text class="hero-badge-dot"></text>
      <text class="hero-badge-text">Claude Code Architecture</text>
    </view>
    <text class="hero-title">{{t.home.hero_title}}</text>
    <text class="hero-subtitle">{{t.home.hero_subtitle}}</text>

    <!-- 进度条 -->
    <view class="hero-progress" wx:if="{{readCount > 0}}">
      <view class="progress-bar">
        <view class="progress-fill" style="width:{{readCount / totalCount * 100}}%"></view>
      </view>
      <text class="progress-text">{{readCount}} / {{totalCount}} 章节</text>
    </view>

    <!-- 开始按钮 -->
    <view class="hero-btn" bindtap="goToStart">
      <text class="hero-btn-text">{{t.home.start}}</text>
      <text class="hero-btn-arrow">→</text>
    </view>

    <!-- 语言切换 -->
    <view class="locale-switcher">
      <text class="locale-btn {{locale=='zh'?'locale-btn--active':''}}"
            bindtap="switchLocale" data-locale="zh">中</text>
      <text class="locale-sep">·</text>
      <text class="locale-btn {{locale=='en'?'locale-btn--active':''}}"
            bindtap="switchLocale" data-locale="en">EN</text>
      <text class="locale-sep">·</text>
      <text class="locale-btn {{locale=='ja'?'locale-btn--active':''}}"
            bindtap="switchLocale" data-locale="ja">日</text>
    </view>
  </view>

  <!-- ======= 学习入口 ======= -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">{{t.home.entry_title}}</text>
      <text class="section-desc">{{t.home.entry_desc}}</text>
    </view>
    <view class="entry-grid">

      <!-- 入口 1：从最小闭环开始 -->
      <view class="entry-card entry-card--start" bindtap="goToStart">
        <view class="entry-icon entry-icon--start">
          <text class="entry-icon-text">⚡</text>
        </view>
        <view class="entry-body">
          <text class="entry-card-title">{{t.home.entry_start_title}}</text>
          <text class="entry-card-desc">{{t.home.entry_start_desc}}</text>
        </view>
        <text class="entry-action">{{t.home.entry_start_action}} →</text>
      </view>

      <!-- 入口 2：时间线 -->
      <view class="entry-card entry-card--timeline" bindtap="goToTimeline">
        <view class="entry-icon entry-icon--timeline">
          <text class="entry-icon-text">📚</text>
        </view>
        <view class="entry-body">
          <text class="entry-card-title">{{t.home.entry_timeline_title}}</text>
          <text class="entry-card-desc">{{t.home.entry_timeline_desc}}</text>
        </view>
        <text class="entry-action">{{t.home.entry_timeline_action}} →</text>
      </view>

      <!-- 入口 3：阶段页 -->
      <view class="entry-card entry-card--layers" bindtap="goToLayers">
        <view class="entry-icon entry-icon--layers">
          <text class="entry-icon-text">🗂</text>
        </view>
        <view class="entry-body">
          <text class="entry-card-title">{{t.home.entry_layers_title}}</text>
          <text class="entry-card-desc">{{t.home.entry_layers_desc}}</text>
        </view>
        <text class="entry-action">{{t.home.entry_layers_action}} →</text>
      </view>

      <!-- 入口 4：对比页 -->
      <view class="entry-card entry-card--compare" bindtap="goToCompare">
        <view class="entry-icon entry-icon--compare">
          <text class="entry-icon-text">🔍</text>
        </view>
        <view class="entry-body">
          <text class="entry-card-title">{{t.home.entry_compare_title}}</text>
          <text class="entry-card-desc">{{t.home.entry_compare_desc}}</text>
        </view>
        <text class="entry-action">{{t.home.entry_compare_action}} →</text>
      </view>

    </view>
  </view>

  <!-- ======= 章节列表（按阶段分组）======= -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">{{t.home.learning_path}}</text>
      <text class="section-desc">{{t.home.learning_path_desc}}</text>
    </view>

    <block wx:for="{{layers}}" wx:key="id">
      <view class="layer-group">

        <!-- 阶段标题行 -->
        <view class="layer-header">
          <view class="layer-dot" style="background:{{item.color}}"></view>
          <text class="layer-label">{{item.label}}</text>
          <text class="layer-count">{{item.versions.length}}{{t.home.versions_in_layer}}</text>
        </view>

        <!-- 章节列表 -->
        <view class="chapter-list">
          <view
            wx:for="{{item.versions}}"
            wx:for-item="chapter"
            wx:key="id"
            class="chapter-item"
            bindtap="goToChapter"
            data-id="{{chapter.id}}"
          >
            <!-- 左侧：章节 ID + 颜色竖线 -->
            <view class="chapter-left">
              <view class="chapter-line" style="background:{{item.color}}"></view>
              <text class="chapter-id">{{chapter.id}}</text>
            </view>

            <!-- 中间：标题 + keyInsight -->
            <view class="chapter-body">
              <view class="chapter-title-row">
                <text class="chapter-title">{{chapter.title}}</text>
                <text class="chapter-subtitle" wx:if="{{chapter.subtitle}}">· {{chapter.subtitle}}</text>
              </view>
              <text class="chapter-insight">{{chapter.keyInsight}}</text>
            </view>

            <!-- 右侧：已读标记 -->
            <view class="chapter-right">
              <view class="chapter-read-badge {{chapter.isRead ? 'chapter-read-badge--done' : ''}}">
                <text class="chapter-read-text">{{chapter.isRead ? '✓' : ''}}</text>
              </view>
            </view>
          </view>
        </view>

      </view>
    </block>
  </view>

  <!-- ======= 阅读提示 ======= -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">{{t.home.guide_label}}</text>
    </view>
    <view class="guide-list">

      <view class="guide-card guide-card--start">
        <view class="guide-card-header">
          <view class="guide-num">01</view>
          <text class="guide-card-title">{{t.home.guide_start_title}}</text>
        </view>
        <text class="guide-card-desc">{{t.home.guide_start_desc}}</text>
      </view>

      <view class="guide-card guide-card--middle">
        <view class="guide-card-header">
          <view class="guide-num">02</view>
          <text class="guide-card-title">{{t.home.guide_middle_title}}</text>
        </view>
        <text class="guide-card-desc">{{t.home.guide_middle_desc}}</text>
      </view>

      <view class="guide-card guide-card--finish">
        <view class="guide-card-header">
          <view class="guide-num">03</view>
          <text class="guide-card-title">{{t.home.guide_finish_title}}</text>
        </view>
        <text class="guide-card-desc">{{t.home.guide_finish_desc}}</text>
      </view>

    </view>
  </view>

  <!-- 底部留白 -->
  <view class="page-footer"></view>

</scroll-view>

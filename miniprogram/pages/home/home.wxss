/* pages/home/home.wxss — V3 Design */

.page {
  height: 100vh;
  background: var(--color-bg);
}

/* ========== Page Header ========== */
.page-header {
  padding: 16rpx 40rpx 0;
}

.header-top {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: baseline;
  margin-bottom: 8rpx;
}

.page-title {
  font-size: 56rpx;
  font-weight: 700;
  letter-spacing: -1rpx;
  line-height: 1.15;
  color: var(--color-text-primary);
}

.page-subtitle {
  display: block;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  margin-top: 8rpx;
  line-height: 1.4;
}

/* Language Switcher — segmented control */
.lang-switcher {
  display: flex;
  flex-direction: row;
  border: 2rpx solid var(--color-border);
  border-radius: 12rpx;
  overflow: hidden;
  flex-shrink: 0;
}

.lang-btn {
  font-size: 24rpx;
  font-weight: 500;
  color: var(--color-text-muted);
  padding: 8rpx 16rpx;
  border-right: 2rpx solid var(--color-border);
  line-height: 1;
}

.lang-btn:last-child {
  border-right: none;
}

.lang-btn.active {
  background: var(--color-text-primary);
  color: #FFFFFF;
  font-weight: 600;
}

/* ========== Progress Strip ========== */
.progress-strip {
  padding: 0 40rpx;
  margin: 32rpx 0 40rpx;
}

.bar-track {
  width: 100%;
  height: 6rpx;
  background: var(--color-border);
  border-radius: 3rpx;
  overflow: hidden;
}

.bar-fill {
  height: 100%;
  border-radius: 3rpx;
  background: var(--color-text-primary);
  transition: width 0.3s;
}

.bar-label {
  display: block;
  font-size: 22rpx;
  font-weight: 500;
  color: var(--color-text-muted);
  margin-top: 12rpx;
  text-align: right;
  font-variant: tabular-nums;
}

/* ========== Quick Entry Grid ========== */
.quick-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  padding: 0 40rpx;
  margin-bottom: 48rpx;
}

.quick-card {
  background: var(--color-bg-card);
  border: 2rpx solid var(--color-border);
  border-radius: 12rpx;
  padding: 28rpx;
}

.quick-card:active {
  background: #F1F5F9;
}

.qc-title {
  display: block;
  font-size: 26rpx;
  font-weight: 500;
  color: var(--color-text-primary);
  line-height: 1.3;
  margin-bottom: 4rpx;
}

.qc-desc {
  display: block;
  font-size: 22rpx;
  color: var(--color-text-muted);
}

/* ========== Chapter List ========== */
.chapters-section {
  padding: 0 40rpx;
}

.layer-group {
  margin-bottom: 48rpx;
}

.layer-group:last-child {
  margin-bottom: 0;
}

.layer-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.layer-header-left {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
}

.layer-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.layer-name {
  font-size: 24rpx;
  font-weight: 600;
  letter-spacing: 0.5rpx;
  color: var(--color-text-secondary);
}

.layer-name-en {
  font-size: 22rpx;
  font-weight: 500;
  color: var(--color-text-muted);
}

.layer-count {
  font-size: 22rpx;
  font-weight: 500;
  color: var(--color-text-muted);
  font-variant: tabular-nums;
}

.layer-count.complete {
  color: var(--color-core);
}

/* Chapter rows */
.chapter-list {
  border-left: 4rpx solid var(--color-border);
  margin-left: 4rpx;
  padding-left: 32rpx;
}

.chapter-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 14rpx 0;
  gap: 16rpx;
}

.chapter-hover {
  opacity: 0.6;
}

.ch-id {
  font-family: 'SF Mono', 'Menlo', monospace;
  font-size: 22rpx;
  font-weight: 500;
  color: var(--color-text-muted);
  width: 52rpx;
  flex-shrink: 0;
}

.ch-title {
  font-size: 28rpx;
  font-weight: 400;
  color: var(--color-text-primary);
  flex: 1;
  line-height: 1.3;
}

/* Read state */
.chapter-row.read .ch-title {
  color: var(--color-text-muted);
}

.chapter-row.read .ch-id {
  color: var(--color-text-faint);
}

/* Status indicators */
.ch-status {
  font-size: 24rpx;
  color: var(--color-core);
  flex-shrink: 0;
  width: 32rpx;
  text-align: center;
}

.ch-arrow {
  font-size: 28rpx;
  color: var(--color-text-muted);
  flex-shrink: 0;
  width: 32rpx;
  text-align: center;
}

/* Next chapter — slightly emphasized */
.chapter-row.next .ch-id {
  color: var(--color-text-secondary);
}

.chapter-row.next .ch-title {
  font-weight: 500;
}

/* ========== Footer ========== */
.page-footer {
  height: 80rpx;
}

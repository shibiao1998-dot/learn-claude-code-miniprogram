/* pages/reference/reference.wxss — V3 Design */

.page {
  height: 100vh;
  background: var(--color-bg);
}

/* ========== Page Header ========== */
.page-header {
  padding: 16rpx 40rpx 0;
  margin-bottom: 40rpx;
}

.header-top {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: baseline;
  margin-bottom: 8rpx;
}

.page-title {
  font-size: 48rpx;
  font-weight: 700;
  letter-spacing: -0.5rpx;
  line-height: 1.2;
  color: var(--color-text-primary);
}

.page-subtitle {
  display: block;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  line-height: 1.4;
}

/* Language Switcher */
.lang-switcher {
  display: flex;
  flex-direction: row;
  border: 2rpx solid var(--color-border);
  border-radius: 12rpx;
  overflow: hidden;
  flex-shrink: 0;
}

.lang-btn {
  font-size: 24rpx;
  font-weight: 500;
  color: var(--color-text-muted);
  padding: 8rpx 16rpx;
  border-right: 2rpx solid var(--color-border);
  line-height: 1;
}

.lang-btn:last-child {
  border-right: none;
}

.lang-btn.active {
  background: var(--color-text-primary);
  color: #FFFFFF;
  font-weight: 600;
}

/* ========== Reference Sections ========== */
.ref-section {
  padding: 0 40rpx;
  margin-bottom: 56rpx;
}

.ref-section:last-of-type {
  margin-bottom: 0;
}

.ref-section-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid var(--color-border);
  margin-bottom: 8rpx;
}

.ref-indicator {
  width: 6rpx;
  height: 28rpx;
  border-radius: 3rpx;
  flex-shrink: 0;
}

.ref-indicator--map {
  background: var(--color-core);
}

.ref-indicator--mechanism {
  background: var(--color-hardening);
}

.ref-section-title {
  font-size: 26rpx;
  font-weight: 600;
  letter-spacing: 0.5rpx;
  color: var(--color-text-secondary);
}

.ref-section-count {
  font-size: 22rpx;
  color: var(--color-text-muted);
  margin-left: auto;
}

/* ========== Doc Rows ========== */
.ref-doc-list {
  display: flex;
  flex-direction: column;
}

.ref-doc-row {
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--color-bg-card);
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.ref-doc-row:last-child {
  border-bottom: none;
}

.doc-hover {
  background: var(--color-bg-card);
  margin-left: -16rpx;
  margin-right: -16rpx;
  padding-left: 16rpx;
  padding-right: 16rpx;
  border-radius: 12rpx;
}

.ref-doc-title {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--color-text-primary);
  line-height: 1.3;
}

.ref-doc-summary {
  font-size: 24rpx;
  color: var(--color-text-muted);
  line-height: 1.4;
}

/* ========== Footer ========== */
.page-footer {
  height: 80rpx;
}

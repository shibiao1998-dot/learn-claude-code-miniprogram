<!-- pages/reference/reference.wxml -->
<scroll-view scroll-y class="page">

  <!-- Page Header -->
  <view class="page-header">
    <view class="header-top">
      <text class="page-title">{{t.reference.title}}</text>
      <view class="lang-switcher">
        <text class="lang-btn {{locale=='zh'?'active':''}}" bindtap="switchLocale" data-locale="zh">中</text>
        <text class="lang-btn {{locale=='en'?'active':''}}" bindtap="switchLocale" data-locale="en">EN</text>
        <text class="lang-btn {{locale=='ja'?'active':''}}" bindtap="switchLocale" data-locale="ja">日</text>
      </view>
    </view>
    <text class="page-subtitle">{{t.reference.subtitle}}</text>
  </view>

  <!-- Foundation Docs (kind=map) -->
  <view class="ref-section">
    <view class="ref-section-header">
      <view class="ref-indicator ref-indicator--map"></view>
      <text class="ref-section-title">{{t.reference.foundation_title}}</text>
      <text class="ref-section-count">{{foundationDocs.length}} {{locale == 'zh' ? '篇' : locale == 'ja' ? '件' : 'docs'}}</text>
    </view>
    <view class="ref-doc-list">
      <view
        wx:for="{{foundationDocs}}"
        wx:key="slug"
        class="ref-doc-row"
        bindtap="openDoc"
        data-slug="{{item.slug}}"
        hover-class="doc-hover"
      >
        <text class="ref-doc-title">{{item.title}}</text>
        <text class="ref-doc-summary">{{item.summary}}</text>
      </view>
    </view>
  </view>

  <!-- Mechanism Docs -->
  <view class="ref-section">
    <view class="ref-section-header">
      <view class="ref-indicator ref-indicator--mechanism"></view>
      <text class="ref-section-title">{{t.reference.deep_dive_title}}</text>
      <text class="ref-section-count">{{mechanismDocs.length}} {{locale == 'zh' ? '篇' : locale == 'ja' ? '件' : 'docs'}}</text>
    </view>
    <view class="ref-doc-list">
      <view
        wx:for="{{mechanismDocs}}"
        wx:key="slug"
        class="ref-doc-row"
        bindtap="openDoc"
        data-slug="{{item.slug}}"
        hover-class="doc-hover"
      >
        <text class="ref-doc-title">{{item.title}}</text>
        <text class="ref-doc-summary">{{item.summary}}</text>
      </view>
    </view>
  </view>

  <view class="page-footer"></view>
</scroll-view>

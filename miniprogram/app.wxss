/* app.wxss — V3 Design System */
page {
  /* Background & Surface */
  --color-bg: #FFFFFF;
  --color-bg-card: #F8FAFC;
  --color-bg-muted: #E2E8F0;

  /* Text hierarchy */
  --color-text-primary: #0F172A;
  --color-text-secondary: #475569;
  --color-text-muted: #94A3B8;
  --color-text-faint: #CBD5E1;

  /* Accent — editorial dark for main pages, blue for interactive elements */
  --color-accent: #0F172A;
  --color-accent-hover: #334155;
  --color-accent-blue: #2563EB;
  --color-accent-blue-hover: #1D4ED8;

  /* Architecture layer colors — used sparingly */
  --color-core: #059669;
  --color-hardening: #2563EB;
  --color-runtime: #7C3AED;
  --color-platform: #DB2777;

  /* Borders */
  --color-border: #E2E8F0;
  --color-border-light: #F1F5F9;

  /* Semantic */
  --color-warning: #D97706;

  /* Radius */
  --radius-xs: 4rpx;
  --radius-sm: 12rpx;
  --radius-md: 16rpx;
  --radius-lg: 24rpx;
  --radius-pill: 200rpx;

  /* Spacing — 4px grid (8rpx = 4px) */
  --spacing-xs: 8rpx;
  --spacing-sm: 16rpx;
  --spacing-md: 24rpx;
  --spacing-lg: 32rpx;
  --spacing-xl: 40rpx;
  --spacing-2xl: 48rpx;

  /* Typography scale */
  --font-2xs: 20rpx;
  --font-xs: 22rpx;
  --font-sm: 26rpx;
  --font-base: 28rpx;
  --font-md: 32rpx;
  --font-lg: 36rpx;
  --font-xl: 44rpx;
  --font-2xl: 48rpx;
  --font-3xl: 56rpx;

  background-color: var(--color-bg);
  color: var(--color-text-primary);
  font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display', 'PingFang SC', 'Noto Sans SC', sans-serif;
  font-size: var(--font-base);
  box-sizing: border-box;
  -webkit-font-smoothing: antialiased;
}

/* Utility classes */
.text-primary { color: var(--color-text-primary); }
.text-secondary { color: var(--color-text-secondary); }
.text-muted { color: var(--color-text-muted); }
.text-faint { color: var(--color-text-faint); }

.layer-core { color: var(--color-core); }
.layer-hardening { color: var(--color-hardening); }
.layer-runtime { color: var(--color-runtime); }
.layer-platform { color: var(--color-platform); }

.layer-bg-core { background-color: rgba(5, 150, 105, 0.06); }
.layer-bg-hardening { background-color: rgba(37, 99, 235, 0.06); }
.layer-bg-runtime { background-color: rgba(124, 58, 237, 0.06); }
.layer-bg-platform { background-color: rgba(219, 39, 119, 0.06); }

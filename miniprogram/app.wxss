/* app.wxss — Light Theme */
page {
  --color-bg: #FFFFFF;
  --color-bg-card: #F8FAFC;
  --color-bg-muted: #E2E8F0;
  --color-text-primary: #0F172A;
  --color-text-secondary: #475569;
  --color-text-muted: #94A3B8;
  --color-accent: #0284C7;
  --color-accent-hover: #0369A1;
  --color-core: #059669;
  --color-hardening: #2563EB;
  --color-runtime: #7C3AED;
  --color-platform: #DB2777;
  --color-border: #E2E8F0;
  --color-warning: #D97706;
  --radius-sm: 8rpx;
  --radius-md: 16rpx;
  --radius-lg: 24rpx;
  --spacing-xs: 8rpx;
  --spacing-sm: 16rpx;
  --spacing-md: 24rpx;
  --spacing-lg: 32rpx;
  --spacing-xl: 48rpx;
  --font-xs: 22rpx;
  --font-sm: 26rpx;
  --font-base: 28rpx;
  --font-md: 32rpx;
  --font-lg: 36rpx;
  --font-xl: 44rpx;
  --font-2xl: 52rpx;

  background-color: var(--color-bg);
  color: var(--color-text-primary);
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', sans-serif;
  font-size: var(--font-base);
  box-sizing: border-box;
}

.card {
  background: var(--color-bg-card);
  border-radius: var(--radius-md);
  border: 1rpx solid var(--color-border);
}

.text-primary { color: var(--color-text-primary); }
.text-secondary { color: var(--color-text-secondary); }
.text-muted { color: var(--color-text-muted); }
.text-accent { color: var(--color-accent); }

.layer-core { color: var(--color-core); }
.layer-hardening { color: var(--color-hardening); }
.layer-runtime { color: var(--color-runtime); }
.layer-platform { color: var(--color-platform); }

.layer-bg-core { background-color: rgba(5, 150, 105, 0.08); }
.layer-bg-hardening { background-color: rgba(37, 99, 235, 0.08); }
.layer-bg-runtime { background-color: rgba(124, 58, 237, 0.08); }
.layer-bg-platform { background-color: rgba(219, 39, 119, 0.08); }

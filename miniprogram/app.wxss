/* app.wxss */
page {
  --color-bg: #0F172A;
  --color-bg-card: #1E293B;
  --color-bg-muted: #334155;
  --color-text-primary: #F1F5F9;
  --color-text-secondary: #94A3B8;
  --color-text-muted: #64748B;
  --color-accent: #38BDF8;
  --color-accent-hover: #7DD3FC;
  --color-core: #34D399;
  --color-hardening: #60A5FA;
  --color-runtime: #A78BFA;
  --color-platform: #F472B6;
  --color-border: #334155;
  --radius-sm: 8rpx;
  --radius-md: 16rpx;
  --radius-lg: 24rpx;
  --spacing-xs: 8rpx;
  --spacing-sm: 16rpx;
  --spacing-md: 24rpx;
  --spacing-lg: 32rpx;
  --spacing-xl: 48rpx;
  --font-xs: 22rpx;
  --font-sm: 26rpx;
  --font-base: 28rpx;
  --font-md: 32rpx;
  --font-lg: 36rpx;
  --font-xl: 44rpx;
  --font-2xl: 52rpx;

  background-color: var(--color-bg);
  color: var(--color-text-primary);
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', sans-serif;
  font-size: var(--font-base);
  box-sizing: border-box;
}

* {
  box-sizing: border-box;
}

.card {
  background: var(--color-bg-card);
  border-radius: var(--radius-md);
  border: 1rpx solid var(--color-border);
}

.text-primary { color: var(--color-text-primary); }
.text-secondary { color: var(--color-text-secondary); }
.text-muted { color: var(--color-text-muted); }
.text-accent { color: var(--color-accent); }

.layer-core { color: var(--color-core); }
.layer-hardening { color: var(--color-hardening); }
.layer-runtime { color: var(--color-runtime); }
.layer-platform { color: var(--color-platform); }

.layer-bg-core { background-color: rgba(52, 211, 153, 0.12); }
.layer-bg-hardening { background-color: rgba(96, 165, 250, 0.12); }
.layer-bg-runtime { background-color: rgba(167, 139, 250, 0.12); }
.layer-bg-platform { background-color: rgba(244, 114, 182, 0.12); }

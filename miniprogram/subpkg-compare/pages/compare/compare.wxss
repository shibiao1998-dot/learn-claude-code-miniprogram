/* subpkg-compare/pages/compare/compare.wxss */

/* ── 页面根容器 ────────────────────────────── */
.page {
  height: 100vh;
  background: var(--color-bg);
  box-sizing: border-box;
}

/* ── 通用区块 ──────────────────────────────── */
.section {
  margin: 0 var(--spacing-md) var(--spacing-md);
}

.section-title {
  display: block;
  font-size: var(--font-sm);
  font-weight: 600;
  color: var(--color-text-secondary);
  text-transform: uppercase;
  letter-spacing: 2rpx;
  margin-bottom: var(--spacing-sm);
}

.section-label {
  display: block;
  font-size: var(--font-base);
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: var(--spacing-xs);
}

/* ── 头部 ──────────────────────────────────── */
.header {
  padding: var(--spacing-xl) var(--spacing-md) var(--spacing-md);
  border-bottom: 1rpx solid var(--color-border);
  margin-bottom: var(--spacing-md);
}

.header-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}

.header-title {
  display: block;
  font-size: var(--font-xl);
  font-weight: 700;
  color: var(--color-text-primary);
  margin-bottom: var(--spacing-xs);
}

.header-subtitle {
  display: block;
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
  line-height: 1.5;
  max-width: 500rpx;
}

/* ── 语言切换 ──────────────────────────────── */
.locale-switcher {
  display: flex;
  align-items: center;
  flex-shrink: 0;
  margin-left: var(--spacing-sm);
}

.locale-btn {
  font-size: var(--font-xs);
  color: var(--color-text-muted);
  padding: 4rpx 8rpx;
  border-radius: var(--radius-sm);
  transition: color 0.2s;
}

.locale-btn.locale-active {
  color: var(--color-accent-blue);
  font-weight: 700;
}

.locale-sep {
  font-size: var(--font-xs);
  color: var(--color-border);
  margin: 0 2rpx;
}

/* ── 选择器区域 ────────────────────────────── */
.selector-section {
  background: var(--color-bg-card);
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-lg);
  padding: var(--spacing-md);
}

.selector-note {
  display: block;
  font-size: var(--font-xs);
  color: var(--color-text-muted);
  margin-bottom: var(--spacing-md);
}

.selector-row {
  display: flex;
  align-items: flex-end;
  gap: var(--spacing-sm);
}

.selector-col {
  flex: 1;
  min-width: 0;
}

.selector-tag {
  display: inline-block;
  font-size: var(--font-xs);
  font-weight: 700;
  padding: 2rpx 12rpx;
  border-radius: var(--radius-sm);
  margin-bottom: var(--spacing-xs);
}

.tag-a {
  background: rgba(5, 150, 105, 0.15);
  color: var(--color-core);
  border: 1rpx solid rgba(5, 150, 105, 0.4);
}

.tag-b {
  background: rgba(37, 99, 235, 0.15);
  color: var(--color-hardening);
  border: 1rpx solid rgba(37, 99, 235, 0.4);
}

/* picker 按钮 */
.picker-btn {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: var(--color-bg-muted);
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-md);
  padding: var(--spacing-sm) var(--spacing-md);
  min-height: 72rpx;
  box-sizing: border-box;
  transition: border-color 0.2s;
}

.picker-btn--selected {
  border-color: var(--color-accent-blue);
}

.picker-text {
  font-size: var(--font-xs);
  color: var(--color-text-secondary);
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.picker-btn--selected .picker-text {
  color: var(--color-text-primary);
  font-weight: 500;
}

.picker-arrow {
  font-size: 18rpx;
  color: var(--color-text-muted);
  margin-left: 8rpx;
  flex-shrink: 0;
}

/* 交换按钮 */
.swap-btn {
  width: 64rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--color-bg-muted);
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-md);
  flex-shrink: 0;
  margin-bottom: 0;
}

.swap-btn--disabled {
  opacity: 0.35;
}

.swap-icon {
  font-size: var(--font-md);
  color: var(--color-accent-blue);
}

/* ── 空状态 ────────────────────────────────── */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 96rpx var(--spacing-md);
  gap: var(--spacing-md);
}

.empty-icon {
  font-size: 80rpx;
  opacity: 0.3;
}

.empty-text {
  font-size: var(--font-sm);
  color: var(--color-text-muted);
  text-align: center;
  line-height: 1.6;
}

/* ── 跃迁诊断卡 ────────────────────────────── */
.progression-card {
  background: var(--color-bg-card);
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-lg);
  padding: var(--spacing-md);
}

/* 跃迁类型 badge */
.progression-badge {
  display: inline-flex;
  align-items: center;
  padding: var(--spacing-xs) var(--spacing-md);
  border-radius: var(--radius-md);
  margin-bottom: var(--spacing-md);
  border: 1rpx solid transparent;
}

.progression-label {
  font-size: var(--font-sm);
  font-weight: 600;
  line-height: 1.5;
}

/* 颜色方案 */
.progression-badge--progression_direct {
  background: rgba(5, 150, 105, 0.12);
  border-color: rgba(5, 150, 105, 0.35);
}
.progression-badge--progression_direct .progression-label {
  color: var(--color-core);
}

.progression-badge--progression_same_layer {
  background: rgba(250, 204, 21, 0.12);
  border-color: rgba(250, 204, 21, 0.35);
}
.progression-badge--progression_same_layer .progression-label {
  color: var(--color-warning);
}

.progression-badge--progression_cross_layer {
  background: rgba(251, 146, 60, 0.12);
  border-color: rgba(251, 146, 60, 0.35);
}
.progression-badge--progression_cross_layer .progression-label {
  color: #EA580C;
}

.progression-badge--progression_reverse {
  background: rgba(148, 163, 184, 0.1);
  border-color: rgba(148, 163, 184, 0.25);
}
.progression-badge--progression_reverse .progression-label {
  color: var(--color-text-muted);
}

.progression-badge--progression_same_chapter {
  background: rgba(148, 163, 184, 0.1);
  border-color: rgba(148, 163, 184, 0.2);
}
.progression-badge--progression_same_chapter .progression-label {
  color: var(--color-text-muted);
}

/* 统计行 */
.stats-row {
  display: flex;
  align-items: center;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.stat-value {
  font-size: var(--font-2xl);
  font-weight: 700;
  color: var(--color-text-primary);
  line-height: 1;
}

.stat-value--delta {
  color: var(--color-core);
}

.stat-label {
  font-size: var(--font-xs);
  color: var(--color-text-muted);
  text-align: center;
}

.stat-divider {
  width: 1rpx;
  height: 48rpx;
  background: var(--color-border);
}

/* ── A / B 章节卡片 ────────────────────────── */
.ab-cards {
  display: flex;
  flex-direction: column;
  gap: 0;
}

.chapter-card {
  background: var(--color-bg-card);
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-lg);
  display: flex;
  flex-direction: row;
  overflow: hidden;
  position: relative;
}

.card-stripe {
  width: 6rpx;
  flex-shrink: 0;
}

.card-body {
  padding: var(--spacing-md);
  flex: 1;
  min-width: 0;
}

.card-header-row {
  display: flex;
  align-items: center;
  gap: var(--spacing-xs);
  margin-bottom: var(--spacing-xs);
}

.card-id-badge {
  font-size: var(--font-xs);
  font-weight: 700;
  padding: 2rpx 10rpx;
  border-radius: var(--radius-sm);
  border: 1rpx solid;
  background: transparent;
}

.card-layer-label {
  font-size: var(--font-xs);
  opacity: 0.8;
}

.card-title {
  display: block;
  font-size: var(--font-md);
  font-weight: 700;
  color: var(--color-text-primary);
  margin-bottom: 8rpx;
}

.card-subtitle {
  display: block;
  font-size: var(--font-xs);
  color: var(--color-text-secondary);
  margin-bottom: 8rpx;
}

.card-addition {
  display: block;
  font-size: var(--font-xs);
  color: var(--color-text-muted);
  margin-bottom: 8rpx;
  padding: 6rpx 12rpx;
  background: var(--color-bg-muted);
  border-radius: var(--radius-sm);
  font-family: monospace;
}

.card-insight {
  display: block;
  font-size: var(--font-xs);
  color: var(--color-text-secondary);
  font-style: italic;
  line-height: 1.5;
  margin-bottom: 8rpx;
}

.card-loc {
  display: block;
  font-size: var(--font-xs);
  color: var(--color-text-muted);
  margin-top: var(--spacing-xs);
}

/* 箭头分隔符 */
.arrow-divider {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: var(--spacing-sm) var(--spacing-md);
}

.arrow-line {
  flex: 1;
  height: 1rpx;
  background: var(--color-border);
}

.arrow-icon {
  font-size: var(--font-lg);
  color: var(--color-accent-blue);
  padding: 0 var(--spacing-sm);
  flex-shrink: 0;
}

.arrow-icon--reverse {
  transform: rotate(180deg);
  color: var(--color-text-muted);
}

/* ── 新增内容 ──────────────────────────────── */
.new-group {
  margin-bottom: var(--spacing-sm);
  background: var(--color-bg-card);
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-md);
  padding: var(--spacing-sm) var(--spacing-md);
}

.new-group-label {
  display: block;
  font-size: var(--font-xs);
  color: var(--color-text-muted);
  margin-bottom: 8rpx;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 1rpx;
}

.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.tag {
  font-size: var(--font-xs);
  padding: 4rpx 14rpx;
  border-radius: var(--radius-sm);
  font-family: monospace;
}

.tag--tool {
  background: rgba(2, 132, 199, 0.15);
  color: var(--color-accent-blue);
  border: 1rpx solid rgba(2, 132, 199, 0.3);
}

.tag--class {
  background: rgba(124, 58, 237, 0.15);
  color: var(--color-runtime);
  border: 1rpx solid rgba(124, 58, 237, 0.3);
}

.tag--func {
  background: rgba(5, 150, 105, 0.15);
  color: var(--color-core);
  border: 1rpx solid rgba(5, 150, 105, 0.3);
}

/* ── 工具对比三列 ───────────────────────────── */
.tool-grid {
  display: flex;
  gap: var(--spacing-xs);
}

.tool-col {
  flex: 1;
  min-width: 0;
  background: var(--color-bg-card);
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-md);
  overflow: hidden;
}

.tool-col-header {
  padding: var(--spacing-xs) var(--spacing-sm);
  border-bottom: 1rpx solid var(--color-border);
}

.tool-col-header--a {
  background: rgba(5, 150, 105, 0.08);
}

.tool-col-header--shared {
  background: rgba(148, 163, 184, 0.06);
}

.tool-col-header--b {
  background: rgba(37, 99, 235, 0.08);
}

.tool-col-title {
  font-size: var(--font-xs);
  font-weight: 600;
  color: var(--color-text-secondary);
  display: block;
  text-align: center;
}

.tool-col-body {
  padding: var(--spacing-sm);
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  min-height: 80rpx;
}

.tool-chip {
  display: block;
  font-size: 20rpx;
  padding: 4rpx 10rpx;
  border-radius: var(--radius-sm);
  font-family: monospace;
  text-align: center;
  line-height: 1.4;
  word-break: break-all;
}

.tool-chip--old {
  background: rgba(5, 150, 105, 0.1);
  color: var(--color-core);
  border: 1rpx solid rgba(5, 150, 105, 0.2);
}

.tool-chip--shared {
  background: rgba(148, 163, 184, 0.1);
  color: var(--color-text-secondary);
  border: 1rpx solid rgba(148, 163, 184, 0.2);
}

.tool-chip--new {
  background: rgba(37, 99, 235, 0.1);
  color: var(--color-hardening);
  border: 1rpx solid rgba(37, 99, 235, 0.2);
}

.none-text {
  font-size: var(--font-xs);
  color: var(--color-text-muted);
  text-align: center;
  display: block;
  padding: var(--spacing-xs) 0;
  opacity: 0.5;
}

/* ── 底部安全间距 ───────────────────────────── */
.page-bottom-pad {
  height: var(--spacing-xl);
}
